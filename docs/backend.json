
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "User's core identity and global role.",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["parent", "adult_player", "coach", "admin"] },
        "activePlanId": { "type": "string" },
        "proTeamLimit": { "type": "number" }
      }
    },
    "PlayerProfile": {
      "title": "PlayerProfile",
      "type": "object",
      "description": "Athletic profile for minors or adults, used for recruitment and roster compliance.",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "dateOfBirth": { "type": "string" },
        "parentId": { "type": "string" },
        "userId": { "type": "string" },
        "isMinor": { "type": "boolean" },
        "recruitingProfileEnabled": { "type": "boolean" }
      }
    },
    "Team": {
      "title": "Team",
      "type": "object",
      "description": "A squad coordination unit.",
      "properties": {
        "id": { "type": "string" },
        "teamName": { "type": "string" },
        "teamCode": { "type": "string" },
        "sport": { "type": "string" },
        "isPro": { "type": "boolean" },
        "ownerUserId": { "type": "string" }
      }
    },
    "RegistrationEntry": {
      "title": "RegistrationEntry",
      "type": "object",
      "description": "A recruitment application for a league or team.",
      "properties": {
        "id": { "type": "string" },
        "league_id": { "type": "string" },
        "protocol_id": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "assigned", "accepted", "declined"] },
        "answers": { "type": "object" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Global user data."
    },
    "/players/{playerId}": {
      "schema": { "$ref": "#/entities/PlayerProfile" },
      "description": "Athletic portfolios."
    },
    "/teams/{teamId}": {
      "schema": { "$ref": "#/entities/Team" },
      "description": "Squad data and subcollections."
    },
    "/leagues/{leagueId}": {
      "description": "League management and registration entries."
    },
    "/plans": {
      "description": "Subscription tier definitions."
    },
    "/subscriptions/{userId}": {
      "description": "Active entitlements from RevenueCat."
    }
  }
}
