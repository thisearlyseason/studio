
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user account in the SquadForge application, storing personal and contact information.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "fullName": {
          "type": "string",
          "description": "The user's full name."
        },
        "email": {
          "type": "string",
          "description": "The user's email address.",
          "format": "email"
        },
        "phone": {
          "type": "string",
          "description": "The user's cell phone number (optional)."
        },
        "avatarUrl": {
          "type": "string",
          "description": "URL to the user's profile avatar image (optional).",
          "format": "uri"
        },
        "notificationsEnabled": {
          "type": "boolean",
          "description": "Indicates if the user has globally enabled push notifications."
        },
        "role": {
          "type": "string",
          "enum": ["parent", "adult_player", "coach", "admin"],
          "description": "The primary role of the user account."
        },
        "subscriptionPlan": {
          "type": "string",
          "enum": ["free", "squad_pro", "elite_teams", "elite_league"],
          "description": "The current subscription plan ID."
        },
        "subscriptionStatus": {
          "type": "string",
          "enum": ["active", "inactive", "trial"],
          "description": "The status of the subscription."
        },
        "proTeamLimit": {
          "type": "number",
          "description": "The maximum number of teams this user can assign Pro features to."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the user account was created.",
          "format": "date-time"
        },
        "isDemo": {
          "type": "boolean",
          "description": "Flag indicating if this is a demo account."
        }
      },
      "required": [
        "id",
        "fullName",
        "email",
        "role",
        "subscriptionPlan",
        "createdAt"
      ]
    },
    "Team": {
      "title": "Team",
      "type": "object",
      "description": "Represents a sports team or group within the application.",
      "properties": {
        "id": { "type": "string" },
        "teamName": { "type": "string" },
        "sport": { "type": "string" },
        "description": { "type": "string" },
        "teamLogoUrl": { "type": "string", "format": "uri" },
        "heroImageUrl": { "type": "string", "format": "uri" },
        "teamCode": { "type": "string" },
        "ownerUserId": { "type": "string" },
        "clubId": { "type": "string" },
        "teamType": { "type": "string", "enum": ["starter", "pro"] },
        "planId": { "type": "string" },
        "isPro": { "type": "boolean" },
        "leagueIds": { "type": "array", "items": { "type": "string" } },
        "parentChatEnabled": { "type": "boolean" },
        "parentCommentsEnabled": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "teamName", "teamCode", "ownerUserId", "teamType"]
    },
    "League": {
      "title": "League",
      "type": "object",
      "description": "A competitive coordination hub for multiple teams.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "sport": { "type": "string" },
        "creatorId": { "type": "string" },
        "teams": { 
          "type": "object",
          "description": "Map of teamId to stats (teamName, wins, losses, points)"
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "creatorId"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "Private user profiles."
    },
    "/teams/{teamId}": {
      "schema": { "$ref": "#/backend/entities/Team" },
      "description": "Collaborative team hubs."
    },
    "/leagues/{leagueId}": {
      "schema": { "$ref": "#/backend/entities/League" },
      "description": "Competitive coordination hubs."
    },
    "/subscriptions/{subId}": {
      "schema": { "type": "object" },
      "description": "Subscription records."
    }
  }
}
