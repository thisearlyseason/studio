
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Private user profile and subscription status.",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["parent", "adult_player", "coach", "admin"] },
        "subscriptionPlan": { "type": "string", "enum": ["free", "squad_pro", "elite_teams", "elite_league"] },
        "subscriptionStatus": { "type": "string", "enum": ["active", "inactive", "trial"] },
        "proTeamLimit": { "type": "number" },
        "isDemo": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "fullName", "email", "role", "subscriptionPlan", "createdAt"]
    },
    "Player": {
      "title": "Player",
      "type": "object",
      "description": "A player profile, potentially linked to a parent guardian.",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "dateOfBirth": { "type": "string", "format": "date" },
        "guardianId": { "type": "string" },
        "isMinor": { "type": "boolean" },
        "joinedTeamIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "League": {
      "title": "League",
      "type": "object",
      "description": "A master hub for managing multiple squads and recruitment.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "sport": { "type": "string" },
        "creatorId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "completed"] },
        "teams": { "type": "object" },
        "isPublic": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "Private user data."
    },
    "/players/{playerId}": {
      "schema": { "$ref": "#/backend/entities/Player" },
      "description": "Central player profiles for the Family Hub."
    },
    "/teams/{teamId}": {
      "schema": { "$ref": "#/backend/entities/Team" },
      "description": "Squad coordination data."
    },
    "/leagues/{leagueId}": {
      "schema": { "$ref": "#/backend/entities/League" },
      "description": "Elite recruitment and standings hubs."
    }
  }
}
