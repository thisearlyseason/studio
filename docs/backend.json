
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user account in the SquadForge application, storing personal and contact information.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "fullName": {
          "type": "string",
          "description": "The user's full name."
        },
        "email": {
          "type": "string",
          "description": "The user's email address, used for login and communication.",
          "format": "email"
        },
        "phone": {
          "type": "string",
          "description": "The user's cell phone number (optional)."
        },
        "avatarUrl": {
          "type": "string",
          "description": "URL to the user's profile avatar image (optional).",
          "format": "uri"
        },
        "notificationsEnabled": {
          "type": "boolean",
          "description": "Indicates if the user has globally enabled push notifications."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the user account was created.",
          "format": "date-time"
        },
        "isDemo": {
          "type": "boolean",
          "description": "Flag indicating if this is a demo admin account."
        },
        "activePlanId": {
          "type": "string",
          "description": "The ID of the plan currently active for the user's account."
        },
        "planSource": {
          "type": "string",
          "enum": [
            "free",
            "revenuecat",
            "manual"
          ],
          "description": "The source of the active subscription state."
        },
        "proTeamLimit": {
          "type": "number",
          "description": "The maximum number of teams this user can assign Pro features to."
        },
        "tournamentCredits": {
          "type": "number",
          "description": "Number of Elite Tournament module credits remaining."
        },
        "revenueCatUserId": {
          "type": "string",
          "description": "The unique identifier for this user in RevenueCat."
        }
      },
      "required": [
        "id",
        "fullName",
        "email",
        "notificationsEnabled",
        "createdAt"
      ]
    },
    "Club": {
      "title": "Club",
      "type": "object",
      "description": "Represents a multi-team organization.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ownerUserId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "ownerUserId"]
    },
    "Team": {
      "title": "Team",
      "type": "object",
      "description": "Represents a sports team or group within the application.",
      "properties": {
        "id": { "type": "string" },
        "teamName": { "type": "string" },
        "sport": { "type": "string" },
        "description": { "type": "string" },
        "teamLogoUrl": { "type": "string", "format": "uri" },
        "teamCode": { "type": "string" },
        "ownerUserId": { "type": "string" },
        "clubId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "planId": { "type": "string" },
        "isPro": { "type": "boolean" },
        "leagueIds": { "type": "array", "items": { "type": "string" } },
        "parentChatEnabled": { "type": "boolean" },
        "parentCommentsEnabled": { "type": "boolean" }
      },
      "required": ["id", "teamName", "teamCode", "ownerUserId"]
    },
    "League": {
      "title": "League",
      "type": "object",
      "description": "A competitive coordination hub for multiple teams.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "sport": { "type": "string" },
        "creatorId": { "type": "string" },
        "teams": { 
          "type": "object",
          "description": "Map of teamId to stats (wins, losses, points)"
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "creatorId"]
    },
    "LeagueInvite": {
      "title": "LeagueInvite",
      "type": "object",
      "properties": {
        "leagueId": { "type": "string" },
        "leagueName": { "type": "string" },
        "invitedEmail": { "type": "string", "format": "email" },
        "status": { "type": "string", "enum": ["pending", "accepted", "declined"] }
      }
    },
    "RegistrationEntry": {
      "title": "RegistrationEntry",
      "type": "object",
      "properties": {
        "league_id": { "type": "string" },
        "answers": { "type": "object" },
        "status": { "type": "string", "enum": ["pending", "accepted", "assigned", "declined"] },
        "assigned_team_id": { "type": "string" },
        "payment_received": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "Private user profiles."
    },
    "/clubs/{clubId}": {
      "schema": { "$ref": "#/backend/entities/Club" },
      "description": "Multi-team organizations."
    },
    "/teams/{teamId}": {
      "schema": { "$ref": "#/backend/entities/Team" },
      "description": "Collaborative team hubs."
    },
    "/leagues/{leagueId}": {
      "schema": { "$ref": "#/backend/entities/League" },
      "description": "Competitive coordination hubs."
    },
    "/leagues/{leagueId}/registrationEntries/{entryId}": {
      "schema": { "$ref": "#/backend/entities/RegistrationEntry" },
      "description": "Public enrollment submissions."
    },
    "/leagues/global/invites/{inviteId}": {
      "schema": { "$ref": "#/backend/entities/LeagueInvite" },
      "description": "Cross-platform recruitment invitations."
    }
  }
}
