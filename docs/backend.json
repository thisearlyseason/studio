{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "avatarUrl": { "type": "string", "format": "uri" },
        "notificationsEnabled": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "fullName", "email"]
    },
    "Team": {
      "title": "Team",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "teamName": { "type": "string" },
        "sport": { "type": "string" },
        "teamCode": { "type": "string" },
        "createdBy": { "type": "string" },
        "members": { "type": "object" },
        "isPro": { "type": "boolean" }
      }
    },
    "TeamMember": {
      "title": "TeamMember",
      "description": "Denormalized membership record stored under users/{uid}/teamMemberships/{teamId} for fast access and rules compatibility.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "teamId": { "type": "string" },
        "teamName": { "type": "string" },
        "teamCode": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "Member"] },
        "sport": { "type": "string" },
        "isPro": { "type": "boolean" },
        "joinedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "description": "Private user profile."
        }
      },
      {
        "path": "/users/{userId}/teamMemberships/{teamId}",
        "definition": {
          "entityName": "TeamMember",
          "description": "Critical lookup path for team access. Contains denormalized team metadata for listing without public collection access."
        }
      },
      {
        "path": "/teams/{teamId}",
        "definition": {
          "entityName": "Team",
          "description": "Core team documents. List restricted."
        }
      }
    ]
  }
}
