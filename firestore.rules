
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // HELPER FUNCTIONS
    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.get('email', '') == 'thisearlyseason@gmail.com' || 
        request.auth.token.get('email', '') == 'test@gmail.com'
      );
    }

    function isDemoTeam(teamId) {
      return teamId.size() >= 5 && teamId[0:5] == 'demo_';
    }

    function isTeamMember(teamId) {
      return isSignedIn() && (
        isDemoTeam(teamId) || 
        isSuperAdmin() ||
        exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid))
      );
    }

    // CORE ADDITIVE RULES
    match /users/{userId} {
      allow read, write: if isSignedIn();
    }

    match /subscriptions/{subscriptionId} {
      allow read, write: if isSignedIn();
    }

    match /teams/{teamId} {
      allow read, write: if isSignedIn() || isDemoTeam(teamId);
      
      match /members/{memberId} {
        allow read, write: if isSignedIn();
      }
      
      match /events/{eventId} {
        allow read, write: if isSignedIn();
      }
      
      match /games/{gameId} {
        allow read, write: if isSignedIn();
      }
      
      match /groupChats/{chatId} {
        allow read, write: if isSignedIn();
        match /messages/{msgId} { allow read, write: if isSignedIn(); }
      }

      match /files/{fileId} {
        allow read, write: if isSignedIn();
      }

      match /drills/{drillId} {
        allow read, write: if isSignedIn();
      }

      match /alerts/{alertId} {
        allow read, write: if isSignedIn();
      }

      match /volunteers/{oppId} {
        allow read, write: if isSignedIn();
      }

      match /fundraising/{fundId} {
        allow read, write: if isSignedIn();
      }

      match /feedPosts/{postId} {
        allow read, write: if isSignedIn();
        match /comments/{commentId} { allow read, write: if isSignedIn(); }
      }
    }

    match /organizations/{orgId} {
      allow read, write: if isSignedIn();
    }

    match /leagues/{leagueId} {
      allow read, write: if isSignedIn();
      match /registrationEntries/{entryId} {
        allow read, write: if isSignedIn() || request.auth == null;
      }
    }

    // Global Collections
    match /leagues { allow list: if isSignedIn(); }
    match /plans { allow get, list: if true; }
    match /features { allow get, list: if true; }
    match /leads { allow create: if true; }
    match /players/{playerId} { allow read, write: if isSignedIn(); }
    match /leagues/global/invites/{inviteId} { allow read, write: if isSignedIn(); }

    // Collection Group Helpers
    match /{path=**}/members/{memberId} { allow read: if isSignedIn(); }
    match /{path=**}/events/{eventId} { allow read: if isSignedIn(); }
    match /{path=**}/alerts/{alertId} { allow read: if isSignedIn(); }
    match /{path=**}/registrationEntries/{entryId} { allow read: if true; }
  }
}
