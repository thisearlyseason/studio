rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- CORE AUTHORIZATION HELPERS ---

    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- BROAD HIERARCHY MATCHES (FOR PROVABLE LISTING) ---

    // LEAGUES: Accessible to all signed-in users for recruitment and standings
    match /leagues/{leagueId} {
      allow read, write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // TEAMS: Accessible to members. Demo teams are open to all guest users.
    match /teams/{teamId} {
      allow read, write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // USERS: Private user data restricted to the owner
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // PLAYERS: Player profiles accessible to signed-in users for recruiting
    match /players/{playerId} {
      allow read, write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // FACILITIES: Venue data for coordination
    match /facilities/{facilityId} {
      allow read, write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- COLLECTION GROUP ACCESS (FOR AGGREGATE DASHBOARDS) ---
    
    match /{path=**}/registrationEntries/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/members/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/events/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/signatures/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/files/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/incidents/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/alerts/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/teamMemberships/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/hiddenChats/{id} { allow read, write: if isSignedIn(); }

    // --- INFRASTRUCTURE ---

    match /plans/{planId} {
      allow read: if true;
    }

    match /subscriptions/{userId} {
      allow read: if isOwner(userId);
    }

    // --- GLOBAL DEFAULT DENY ---
    match /{path=**} {
      allow read, write: if false;
    }
  }
}