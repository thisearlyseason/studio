rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.get('email', '') == 'thisearlyseason@gmail.com' || 
        request.auth.token.get('email', '') == 'test@gmail.com'
      );
    }

    function isDemoTeam(tid) {
      return tid != null && tid.size() >= 5 && tid[0:5] == 'demo_';
    }

    function isTeamMember(teamId) {
      return isSignedIn() && (
        isDemoTeam(teamId) || 
        isSuperAdmin() ||
        exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid))
      );
    }

    function isTeamAdmin(teamId) {
      return isSignedIn() && (
        isDemoTeam(teamId) ||
        isSuperAdmin() ||
        (exists(/databases/$(database)/documents/teams/$(teamId)) && (
          get(/databases/$(database)/documents/teams/$(teamId)).data.get('ownerUserId', '') == request.auth.uid ||
          (exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid)).data.get('role', '') == 'Admin')
        ))
      );
    }

    function isParent() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'parent'
      );
    }

    match /users/{userId} {
      allow read, update, delete: if isOwner(userId) || isSuperAdmin();
      allow create: if isSignedIn(); 
      
      match /teamMemberships/{membershipId} {
        allow read: if isOwner(userId) || isSuperAdmin();
        allow write: if isOwner(userId) || isSuperAdmin();
      }
    }

    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isTeamAdmin(teamId);

      match /volunteers/{oppId} {
        allow read: if isTeamMember(teamId) && (isTeamAdmin(teamId) || isParent());
        allow create, update, delete: if isTeamAdmin(teamId);
        allow update: if isSignedIn() && isParent() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['signups']);
      }

      match /fundraising/{fundId} {
        allow read: if isTeamMember(teamId) && (isTeamAdmin(teamId) || isParent());
        allow create, update, delete: if isTeamAdmin(teamId);
        allow update: if isSignedIn() && isParent() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participants']);
      }

      match /members/{memberId} {
        allow read: if isSignedIn();
        allow write: if isTeamAdmin(teamId) || isOwner(memberId);
      }

      match /groupChats/{chatId} {
        // Splitting list rule to ensure static path-based authorization for demo guest sessions
        allow list: if isSignedIn() && isDemoTeam(teamId);
        allow list: if isSignedIn() && (isSuperAdmin() || (request.auth.uid in resource.data.memberIds));
        
        allow get: if isSignedIn() && (isDemoTeam(teamId) || isSuperAdmin() || (request.auth.uid in resource.data.memberIds) || exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid)));
        allow create: if isTeamMember(teamId);
        allow update: if isTeamMember(teamId) && (isTeamAdmin(teamId) || request.auth.uid in resource.data.memberIds);
        
        match /messages/{messageId} {
          allow read: if isTeamMember(teamId);
          allow create: if isTeamMember(teamId);
          allow update: if isTeamMember(teamId);
        }
      }
      
      match /events/{eventId} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId);
      }

      match /games/{gameId} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId);
      }
      
      match /drills/{drillId} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId);
      }

      match /files/{fileId} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId);
      }

      match /alerts/{alertId} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId);
      }

      match /feedPosts/{postId} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId);
        
        match /comments/{commentId} {
          allow read: if isTeamMember(teamId);
          allow create: if isTeamMember(teamId);
          allow delete: if isTeamAdmin(teamId) || resource.data.authorId == request.auth.uid;
        }
      }
    }

    match /plans/{planId} {
      allow get, list: if true;
    }

    match /features/{featureId} {
      allow get, list: if true;
    }

    match /leads/{leadId} {
      allow create: if true;
    }
  }
}