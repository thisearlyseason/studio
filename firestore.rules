rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- TACTICAL HELPERS ---
    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- INSTITUTIONAL HIERARCHY ---
    // Grant access to leagues/teams and ALL their sub-collections.
    // This single rule is more robust and covers any sub-collection like
    // 'alerts', 'registrationEntries', etc.
    match /leagues/{leagueId} {
      allow read, write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    match /teams/{teamId} {
      allow read, write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- GLOBAL REPOSITORIES ---
    match /plans/{planId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /features/{featureId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /facilities/{facilityId} {
      allow read, write: if isSignedIn();
       match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    match /team_memberships/{membershipId} {
      allow read, write: if isSignedIn();
    }

    // --- PERSONAL INFRASTRUCTURE ---
    match /userProfiles/{userId} {
      allow read, write: if isOwner(userId);
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    match /players/{playerId} {
      allow read, write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- COLLECTION GROUP RULES --- 
    // These are no longer needed for the failing collections, but we'll keep them 
    // for any cross-collection queries you may have.
    match /{path=**}/registrationEntries/{id} { allow list, read, write: if isSignedIn(); }
    match /{path=**}/members/{id} { allow list, read, write: if isSignedIn(); }
    match /{path=**}/events/{id} { allow list, read, write: if isSignedIn(); }
    match /{path=**}/files/{id} { allow list, read, write: if isSignedIn(); }
    match /{path=**}/incidents/{id} { allow list, read, write: if isSignedIn(); }
    match /{path=**}/feedPosts/{id} { allow list, read, write: if isSignedIn(); }
    match /{path=**}/groupChats/{id} { allow list, read, write: if isSignedIn(); }
    match /{path=**}/volunteers/{id} { allow list, read, write: if isSignedIn(); }
    match /{path=**}/fundraising/{id} { allow list, read, write: if isSignedIn(); }
    match /{path=**}/drills/{id} { allow list, read, write: if isSignedIn(); }
    match /{path=**}/games/{id} { allow list, read, write: if isSignedIn(); }
    match /{path=**}/equipment/{id} { allow list, read, write: if isSignedIn(); }
    match /{path=**}/signatures/{id} { allow list, read, write: if isSignedIn(); }
  }
}
