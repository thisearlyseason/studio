rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- CORE AUTHORIZATION HELPERS ---

    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- INSTITUTIONAL HIERARCHY ---
    // Explicit matches for subcollections ensure that 'list' operations can be 
    // statically proved by the rules engine, preventing 403 errors.

    match /leagues/{leagueId} {
      allow read, write: if isSignedIn();
      
      // Explicit subcollection matching for List Proving
      match /registration/{configId} {
        allow read, write: if isSignedIn();
      }
      
      match /registrationEntries/{entryId} {
        allow read, write: if isSignedIn();
      }
      
      match /payments/{paymentId} {
        allow read, write: if isSignedIn();
      }
    }

    match /teams/{teamId} {
      allow read, write: if isSignedIn();

      match /members/{memberId} {
        allow read, write: if isSignedIn();
      }

      match /events/{eventId} {
        allow read, write: if isSignedIn();
      }

      match /feedPosts/{postId} {
        allow read, write: if isSignedIn();
        
        match /comments/{commentId} {
          allow read, write: if isSignedIn();
        }
      }

      match /groupChats/{chatId} {
        allow read, write: if isSignedIn();
        
        match /messages/{messageId} {
          allow read, write: if isSignedIn();
        }
        
        match /polls/{pollId} {
          allow read, write: if isSignedIn();
        }
      }

      match /equipment/{itemId} {
        allow read, write: if isSignedIn();
      }

      match /incidents/{incidentId} {
        allow read, write: if isSignedIn();
      }

      match /volunteers/{oppId} {
        allow read, write: if isSignedIn();
      }

      match /fundraising/{fundId} {
        allow read, write: if isSignedIn();
        
        match /donations/{donId} {
          allow read, write: if isSignedIn();
        }
      }

      match /drills/{drillId} {
        allow read, write: if isSignedIn();
      }

      match /files/{fileId} {
        allow read, write: if isSignedIn();
      }

      match /games/{gameId} {
        allow read, write: if isSignedIn();
      }
      
      match /documents/{docId} {
        allow read, write: if isSignedIn();
      }
    }

    // --- PERSONNEL & PRIVATE DATA ---

    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /teamMemberships/{membershipId} {
        allow read, write: if isOwner(userId);
      }

      match /hiddenChats/{chatId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /userProfiles/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /players/{playerId} {
      allow read, write: if isSignedIn();

      match /evaluations/{evalId} {
        allow read, write: if isSignedIn();
      }

      match /videos/{videoId} {
        allow read, write: if isSignedIn();
      }

      match /recruitingProfile/{docId} {
        allow read, write: if isSignedIn();
      }
    }

    match /facilities/{facilityId} {
      allow read, write: if isSignedIn();

      match /fields/{fieldId} {
        allow read, write: if isSignedIn();
      }
    }

    match /plans/{planId} {
      allow read: if true;
    }

    match /features/{featureId} {
      allow read: if true;
    }

    // --- COLLECTION GROUP ACCESS ---
    // Specifically authorized for Master Intelligence queries in the Club/Family hubs
    
    match /{path=**}/registrationEntries/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/signatures/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/members/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/events/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/files/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/feedPosts/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/groupChats/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/teamMemberships/{id} { allow read, write: if isSignedIn(); }

    // --- GLOBAL DEFAULT DENY ---
    match /{path=**} {
      allow read, write: if false;
    }
  }
}