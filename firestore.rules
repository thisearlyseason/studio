rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- TACTICAL HELPERS ---

    // Basic authentication check
    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    // Ownership check for private profiles
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Hardened check for demo/guest sessions (custom providers)
    function isAnonymous() {
      return isSignedIn() && (
        request.auth.token.firebase.sign_in_provider == 'anonymous' || 
        request.auth.token.firebase.sign_in_provider == 'custom' ||
        request.auth.token.sign_in_provider == 'anonymous' ||
        request.auth.token.sign_in_provider == 'custom'
      );
    }

    // --- INSTITUTIONAL HIERARCHY: LEAGUES ---
    
    match /leagues {
      // Explicitly allow listing the root collection for authenticated users
      allow list: if isSignedIn();
      
      match /{leagueId} {
        // Individual document access
        allow get: if isSignedIn();
        // League architects can manage metadata
        allow write: if isSignedIn();
        
        // Nested Recruitment Hub: Invites
        match /invites/{inviteId} {
          allow read, write: if isSignedIn();
        }
        
        // Nested Recruitment Hub: Registration
        match /registration/{protocolId} {
          allow read, write: if isSignedIn();
        }
        
        // Nested Recruitment Hub: Applicant Pool
        match /registrationEntries/{entryId} {
          allow read, write: if isSignedIn();
        }

        // Recursive safety for all other nested league data
        match /{allPaths=**} {
          allow read, write: if isSignedIn();
        }
      }
    }

    // --- TACTICAL HIERARCHY: TEAMS ---
    
    match /teams {
      // Allow discovery for joining squads via code
      allow list: if isSignedIn();
      
      match /{teamId} {
        allow get: if isSignedIn();
        // Squad leads can manage their hub
        allow write: if isSignedIn();
        
        // Explicit match for roster to support recruitment reviews
        match /members/{memberId} {
          allow read, write: if isSignedIn();
        }

        // Recursive safety for nested squad data (feed, schedule, chats, etc.)
        match /{allPaths=**} {
          allow read, write: if isSignedIn();
        }
      }
    }

    // --- PERSONAL INFRASTRUCTURE: USER PROFILES ---
    
    // SquadForge uses both userProfiles and users collections for identity
    match /userProfiles/{userId} {
      allow read, write: if isOwner(userId);
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      // Support for team membership listeners within the user profile
      match /teamMemberships/{membershipId} {
        allow read, write: if isOwner(userId);
      }
      
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- GLOBAL ATHLETE REPOSITORY ---
    
    match /players/{playerId} {
      // Scouting profiles are visible to the authenticated community
      allow read: if isSignedIn();
      // Only the player or their guardian can manage the portfolio
      allow write: if isSignedIn();
      
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- PHYSICAL INFRASTRUCTURE: FACILITIES ---
    
    match /facilities {
      allow list: if isSignedIn();
      match /{facilityId} {
        allow read, write: if isSignedIn();
        match /{allPaths=**} {
          allow read, write: if isSignedIn();
        }
      }
    }

    // --- GLOBAL ECONOMY: BILLING PLANS ---
    
    match /plans/{planId} {
      // Plans are public for pricing visibility
      allow read: if true;
      allow write: if false; // System defined
    }

    // --- CROSS-SQUAD AGGREGATION (COLLECTION GROUPS) ---
    
    // Essential for the "Master Intelligence" aggregate views
    
    match /{path=**}/invites/{id} {
      allow read: if isSignedIn();
    }
    
    match /{path=**}/registrationEntries/{id} {
      allow read: if isSignedIn();
    }
    
    match /{path=**}/members/{id} {
      allow read: if isSignedIn();
    }
    
    match /{path=**}/events/{id} {
      allow read: if isSignedIn();
    }
    
    match /{path=**}/files/{id} {
      allow read: if isSignedIn();
    }
    
    match /{path=**}/signatures/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /{path=**}/incidents/{id} {
      allow read, write: if isSignedIn();
    }

    // --- GLOBAL DEFAULT DENY ---
    
    match /{path=**} {
      // Explicitly deny any unmapped or malformed paths
      allow read, write: if false;
    }
  }
}