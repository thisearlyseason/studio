rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isTeamMember(teamId) {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/team_memberships/$(teamId + "_" + request.auth.uid))
      );
    }

    function isTeamAdmin(teamId) {
      return isSignedIn() && (
        get(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid)).data.role == 'Admin' ||
        get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUserId == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // --- User Profiles ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || (request.auth.token.firebase.sign_in_provider == 'anonymous');
      
      match /teamMemberships/{membershipId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) || (request.auth.token.firebase.sign_in_provider == 'anonymous');
      }
      
      match /hiddenChats/{chatId} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- Players ---
    match /players/{playerId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
      
      match /{allPaths=**} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
    }

    // --- Teams ---
    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isTeamAdmin(teamId) || (request.auth.token.firebase.sign_in_provider == 'anonymous');

      match /{allPaths=**} {
        allow read: if isSignedIn();
        allow write: if isTeamAdmin(teamId) || isTeamMember(teamId) || (request.auth.token.firebase.sign_in_provider == 'anonymous');
      }
    }

    // --- Team Memberships ---
    match /team_memberships/{membershipId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // --- Facilities ---
    match /facilities/{facId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
      
      match /{allPaths=**} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
    }

    // --- Leagues ---
    match /leagues/{leagueId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.creatorId || isSuperAdmin());
      
      match /{allPaths=**} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
    }

    function isSuperAdmin() {
      return request.auth.token.email == 'thisearlyseason@gmail.com';
    }

    // --- Global Catalog ---
    match /plans/{planId} {
      allow read: if true;
    }
    match /features/{featureId} {
      allow read: if true;
    }

    // --- Collection Groups ---
    match /{path=**}/events/{eventId} {
      allow read: if isSignedIn();
    }
    match /{path=**}/files/{fileId} {
      allow read: if isSignedIn();
    }
    match /{path=**}/signatures/{sigId} {
      allow read: if isSignedIn();
    }
    match /{path=**}/registrationEntries/{entryId} {
      allow read: if isSignedIn();
    }
    match /{path=**}/members/{memberId} {
      allow read: if isSignedIn();
    }

    // Explicitly deny root document listing
    match / {
      allow list: if false;
    }

    // Deny by default
    match /{path=**} {
      allow read, write: if false;
    }
  }
}