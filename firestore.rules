rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- TACTICAL HELPERS ---

    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- INSTITUTIONAL HIERARCHY: LEAGUES ---
    
    match /leagues {
      allow list, get, create: if isSignedIn();
    }

    match /leagues/{leagueId} {
      allow read, write: if isSignedIn();
      
      // Explicit matches for subcollections to satisfy "List Proving"
      match /registrationEntries/{id} { allow read, write: if isSignedIn(); }
      match /invites/{id} { allow read, write: if isSignedIn(); }
      match /members/{id} { allow read, write: if isSignedIn(); }
      match /events/{id} { allow read, write: if isSignedIn(); }
      match /registration/{id} { allow read, write: if isSignedIn(); }
      match /donations/{id} { allow read, write: if isSignedIn(); }
      match /payments/{id} { allow read, write: if isSignedIn(); }
      
      // Recursive safety for any other nested data
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- TACTICAL HIERARCHY: TEAMS ---
    
    match /teams {
      allow list, get, create: if isSignedIn();
    }

    match /teams/{teamId} {
      allow read, write: if isSignedIn();
      
      // Explicit sub-data matching
      match /members/{id} { allow read, write: if isSignedIn(); }
      match /events/{id} { 
        allow read, write: if isSignedIn(); 
        match /registrations/{regId} { allow read, write: if isSignedIn(); }
      }
      match /games/{id} { allow read, write: if isSignedIn(); }
      match /drills/{id} { allow read, write: if isSignedIn(); }
      match /files/{id} { allow read, write: if isSignedIn(); }
      match /feedPosts/{id} { 
        allow read, write: if isSignedIn(); 
        match /comments/{commentId} { allow read, write: if isSignedIn(); }
      }
      match /groupChats/{id} { 
        allow read, write: if isSignedIn(); 
        match /messages/{msgId} { allow read, write: if isSignedIn(); }
      }
      match /volunteers/{id} { allow read, write: if isSignedIn(); }
      match /fundraising/{id} { 
        allow read, write: if isSignedIn(); 
        match /donations/{donId} { allow read, write: if isSignedIn(); }
      }
      match /equipment/{id} { allow read, write: if isSignedIn(); }
      match /incidents/{id} { allow read, write: if isSignedIn(); }
      match /documents/{id} { allow read, write: if isSignedIn(); }
      
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- PERSONAL INFRASTRUCTURE ---
    
    match /userProfiles/{userId} {
      allow read, write: if isOwner(userId);
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
      match /teamMemberships/{id} { allow read, write: if isOwner(userId); }
      match /hiddenChats/{id} { allow read, write: if isOwner(userId); }
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- GLOBAL REPOSITORIES ---
    
    match /players {
      allow list, get, create: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    match /players/{playerId} {
      allow read, write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    match /facilities {
      allow list, get, create: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    match /plans {
      allow list, get: if true;
      allow write: if isSignedIn();
    }

    match /plans/{planId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /team_memberships {
      allow list, get, create: if isSignedIn();
    }

    match /team_memberships/{id} {
      allow read, write: if isSignedIn();
    }

    // --- CROSS-SQUAD AGGREGATION (COLLECTION GROUPS) ---
    
    match /{path=**}/invites/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/registrationEntries/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/members/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/events/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/files/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/signatures/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/incidents/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/feedPosts/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/groupChats/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/volunteers/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/fundraising/{id} { allow read, write: if isSignedIn(); }

    // --- GLOBAL DEFAULT DENY ---
    match /{path=**} {
      allow read, write: if false;
    }
  }
}