rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SQUADFORGE SECURITY RULES
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** Verifies a user's membership in a specific team via the denormalized path. */
    function isTeamMember(teamId) {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)/teamMemberships/$(teamId));
    }

    /** Verifies if the user is an Admin of a specific team. */
    function isTeamAdmin(teamId) {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)/teamMemberships/$(teamId)).data.role == 'Admin';
    }

    /** Hardcoded Super Admin check for administrative UIDs provided in console errors. */
    function isSuperAdmin() {
      return isSignedIn() && request.auth.uid in ['ai2QThECAwfkAFw608m7TgPZTmk2', 'super-admin-uid-placeholder'];
    }

    function isChatMember(chatData) {
      return isSignedIn() && request.auth.uid in chatData.memberIds;
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSuperAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);

      match /teamMemberships/{teamId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isExistingOwner(userId);
        allow delete: if isExistingOwner(userId);
      }

      match /hiddenChats/{chatId} {
        allow get, list: if isOwner(userId);
        allow create, update, delete: if isOwner(userId);
      }
    }

    match /teams/{teamId} {
      allow get: if isTeamMember(teamId) || isSuperAdmin();
      allow list: if isSuperAdmin();
      allow create: if isSignedIn();
      allow update, delete: if resource != null && (isTeamAdmin(teamId) || isSuperAdmin());

      match /members/{memberId} {
        allow read: if isTeamMember(teamId) || isSuperAdmin();
        allow create, update, delete: if isTeamAdmin(teamId) || isSuperAdmin();
      }

      match /posts/{postId} {
        allow read: if isTeamMember(teamId) || isSuperAdmin();
        allow create: if isTeamMember(teamId);
        allow update, delete: if isTeamMember(teamId) && (isExistingOwner(resource.data.authorId) || isTeamAdmin(teamId));

        match /comments/{commentId} {
          allow read: if isTeamMember(teamId) || isSuperAdmin();
          allow create: if isTeamMember(teamId);
          allow update, delete: if isTeamMember(teamId) && (isExistingOwner(resource.data.authorId) || isTeamAdmin(teamId));
        }
      }

      match /events/{eventId} {
        allow read: if isTeamMember(teamId) || isSuperAdmin();
        allow create, update, delete: if isTeamAdmin(teamId) || isSuperAdmin();

        match /rsvps/{userId} {
          allow read: if isTeamMember(teamId) || isSuperAdmin();
          allow create, update, delete: if isOwner(userId);
        }
      }

      match /games/{gameId} {
        allow read: if isTeamMember(teamId) || isSuperAdmin();
        allow create, update, delete: if isTeamAdmin(teamId) || isSuperAdmin();
      }

      match /drills/{drillId} {
        allow read: if isTeamMember(teamId) || isSuperAdmin();
        allow create, update, delete: if isTeamAdmin(teamId) || isSuperAdmin();
      }

      match /files/{fileId} {
        allow read: if isTeamMember(teamId) || isSuperAdmin();
        allow create: if isTeamMember(teamId);
        allow update, delete: if isTeamAdmin(teamId) || isExistingOwner(resource.data.uploadedBy);
      }

      match /groupChats/{chatId} {
        allow get, list: if isTeamMember(teamId) && (isChatMember(resource.data) || isSuperAdmin());
        allow create: if isTeamMember(teamId);
        allow update: if isTeamMember(teamId) && isChatMember(resource.data);
        allow delete: if isTeamAdmin(teamId) || isSuperAdmin();

        match /messages/{messageId} {
          allow read: if isTeamMember(teamId) && (isChatMember(get(/databases/$(database)/documents/teams/$(teamId)/groupChats/$(chatId)).data) || isSuperAdmin());
          allow create: if isTeamMember(teamId) && isChatMember(get(/databases/$(database)/documents/teams/$(teamId)/groupChats/$(chatId)).data);
          allow update, delete: if isExistingOwner(resource.data.authorId);
        }
      }

      match /alerts/{alertId} {
        allow read: if isTeamMember(teamId) || isSuperAdmin();
        allow create, update, delete: if isTeamAdmin(teamId) || isSuperAdmin();
      }
    }
  }
}
