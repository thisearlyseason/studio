rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SQUADFORGE SECURITY RULES - PROTOTYPING MODE
     *
     * CORE PHILOSOPHY:
     * This ruleset implements a robust, denormalized security model designed for performance and scale. 
     * It prioritizes strict authorization (who can see what) while remaining flexible on data 
     * structures to support rapid prototyping.
     *
     * DATA STRUCTURE & SEGREGATION:
     * 1. User-Centric Data: Located at /users/{userId}. Access is restricted via path-based ownership.
     * 2. Team-Centric Data: Located at /teams/{teamId}. Access is controlled by team membership.
     * 3. Structural Segregation: Private user preferences (hidden chats) are isolated from shared team data.
     *
     * KEY SECURITY DECISIONS:
     * - Authorization Independence: We use denormalized maps (team_members, chat_members) inside 
     *   documents. This allows rules to check permissions without performing expensive get() 
     *   calls to parent documents.
     * - Immutability: Critical relational fields (like authorId or teamId) are enforced as 
     *   immutable on updates to prevent data corruption or privilege escalation.
     * - Relational Integrity: On creation, rules verify that the creator's UID matches the 
     *   provided ID field in the document.
     *
     * NOTE ON 'LEAGUES' ERROR:
     * The reported error regarding '/leagues/global/invites' is outside the scope of the 
     * current data model. Access to that path is explicitly denied until the schema is defined.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks ownership and ensures the document exists for destructive operations. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** @description Checks if a user is a member of a team via a denormalized map. */
    function isTeamMemberInDoc(data) {
      return isSignedIn() && data.team_members[request.auth.uid] != null;
    }

    /** @description Checks if a user is an admin of a team via a denormalized map. */
    function isTeamAdminInDoc(data) {
      return isSignedIn() && data.team_members[request.auth.uid] == 'admin';
    }

    /** @description Checks if a user is a member of a chat via a denormalized map. */
    function isChatMemberInDoc(data) {
      return isSignedIn() && data.chat_members[request.auth.uid] != null;
    }

    /** @description Fetches team membership from the parent team document. */
    function checkTeamMembership(teamId) {
      return get(/databases/$(database)/documents/teams/$(teamId)).data.members[request.auth.uid] != null;
    }

    // --- USER PROFILE RULES ---

    /**
     * @description Rules for the User profile. Only the user can manage their own profile.
     * @path /users/{userId}
     * @allow (get) If signed in as {userId}.
     * @deny (list) If not signed in as the owner.
     * @principle Path-based ownership.
     */
    match /users/{userId} {
      allow get, list, create: if isOwner(userId);
      allow update, delete: if isExistingOwner(userId);

      /**
       * @description Records of chats hidden by a specific user.
       * @path /users/{userId}/hiddenChats/{chatId}
       * @allow (create) If the userId in path matches auth UID.
       * @deny (write) If trying to modify another user's preferences.
       */
      match /hiddenChats/{chatId} {
        allow get, list, create: if isOwner(userId);
        allow update, delete: if isExistingOwner(userId);
      }
    }

    // --- TEAM RULES ---

    /**
     * @description Core team document. Membership is defined in a 'members' map.
     * @path /teams/{teamId}
     * @allow (get) If user is in the members map.
     * @deny (update) If user is not an 'admin' in the map.
     */
    match /teams/{teamId} {
      allow get, list: if isSignedIn() && resource.data.members[request.auth.uid] != null;
      allow create: if isSignedIn() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isSignedIn() && resource.data.members[request.auth.uid] == 'admin';
      allow delete: if false; // Teams are archived or deleted via admin console only.

      /**
       * @description Team membership details.
       * @path /teams/{teamId}/members/{userId}
       * @allow (get) If user is a member of the team.
       */
      match /members/{userId} {
        allow get, list: if checkTeamMembership(teamId);
        allow create, update, delete: if checkTeamMembership(teamId) && get(/databases/$(database)/documents/teams/$(teamId)).data.members[request.auth.uid] == 'admin';
      }

      /**
       * @description Activity feed posts. Access uses denormalized team_members map.
       * @path /teams/{teamId}/posts/{postId}
       */
      match /posts/{postId} {
        allow get, list: if isTeamMemberInDoc(resource.data);
        allow create: if isTeamMemberInDoc(request.resource.data) && request.resource.data.authorId == request.auth.uid;
        allow update: if isExistingOwner(resource.data.authorId) && request.resource.data.authorId == resource.data.authorId;
        allow delete: if isExistingOwner(resource.data.authorId) || isTeamAdminInDoc(resource.data);

        match /comments/{commentId} {
          allow get, list: if isTeamMemberInDoc(resource.data);
          allow create: if isTeamMemberInDoc(request.resource.data) && request.resource.data.authorId == request.auth.uid;
          allow update: if isExistingOwner(resource.data.authorId) && request.resource.data.authorId == resource.data.authorId;
          allow delete: if isExistingOwner(resource.data.authorId) || isTeamAdminInDoc(resource.data);
        }
      }

      /**
       * @description Scheduled events and RSVPs.
       * @path /teams/{teamId}/events/{eventId}
       */
      match /events/{eventId} {
        allow get, list: if isTeamMemberInDoc(resource.data);
        allow create: if isTeamAdminInDoc(request.resource.data);
        allow update: if isTeamAdminInDoc(resource.data);
        allow delete: if isTeamAdminInDoc(resource.data);

        match /rsvps/{rsvpId} {
          allow get, list: if isTeamMemberInDoc(resource.data);
          allow create: if isTeamMemberInDoc(request.resource.data) && request.resource.data.userId == request.auth.uid;
          allow update: if isExistingOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId;
          allow delete: if isExistingOwner(resource.data.userId);
        }
      }

      /**
       * @description Member availability reporting.
       * @path /teams/{teamId}/availability/{availabilityId}
       */
      match /availability/{availabilityId} {
        allow get, list: if isTeamMemberInDoc(resource.data);
        allow create: if isTeamMemberInDoc(request.resource.data) && request.resource.data.userId == request.auth.uid;
        allow update: if isExistingOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(resource.data.userId);
      }

      /**
       * @description Files shared with the team.
       * @path /teams/{teamId}/files/{fileId}
       */
      match /files/{fileId} {
        allow get, list: if isTeamMemberInDoc(resource.data);
        allow create: if isTeamMemberInDoc(request.resource.data) && request.resource.data.uploadedBy == request.auth.uid;
        allow update: if isExistingOwner(resource.data.uploadedBy) && request.resource.data.uploadedBy == resource.data.uploadedBy;
        allow delete: if isExistingOwner(resource.data.uploadedBy) || isTeamAdminInDoc(resource.data);
      }

      /**
       * @description Group chats. Access uses both team_members and chat_members.
       * @path /teams/{teamId}/groupChats/{chatId}
       */
      match /groupChats/{chatId} {
        allow get, list: if isChatMemberInDoc(resource.data);
        allow create: if isTeamMemberInDoc(request.resource.data);
        allow update: if isChatMemberInDoc(resource.data);
        allow delete: if isTeamAdminInDoc(resource.data);

        match /messages/{messageId} {
          allow get, list: if isChatMemberInDoc(resource.data);
          allow create: if isChatMemberInDoc(request.resource.data) && request.resource.data.authorId == request.auth.uid;
          allow update: if isExistingOwner(resource.data.authorId) && request.resource.data.authorId == resource.data.authorId;
          allow delete: if isExistingOwner(resource.data.authorId);
        }

        match /polls/{pollId} {
          allow get, list: if isChatMemberInDoc(resource.data);
          allow create: if isChatMemberInDoc(request.resource.data);
          allow update: if isChatMemberInDoc(resource.data) && isExistingOwner(resource.data.createdBy);
          allow delete: if isChatMemberInDoc(resource.data) && (isExistingOwner(resource.data.createdBy) || isTeamAdminInDoc(resource.data));

          match /votes/{voteId} {
            allow get, list: if isChatMemberInDoc(resource.data);
            allow create: if isChatMemberInDoc(request.resource.data) && request.resource.data.userId == request.auth.uid && request.resource.data.poll_isClosed == false;
            allow update: if isExistingOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId && resource.data.poll_isClosed == false;
            allow delete: if isExistingOwner(resource.data.userId) && resource.data.poll_isClosed == false;
          }
        }
      }
    }

    // --- LEGACY OR UNDEFINED PATHS ---

    /**
     * @description Explicitly deny access to paths not defined in the application requirements.
     * This addresses the reported error on '/leagues/global/invites'.
     */
    match /leagues/{document=**} {
      allow read, write: if false;
    }
  }
}