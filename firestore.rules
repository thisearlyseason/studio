rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- TACTICAL HELPERS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- INSTITUTIONAL HIERARCHY ---
    
    // leagues and their nested coordination data
    match /leagues/{leagueId} {
      allow read, write: if isSignedIn();
      
      // Explicitly allow access to registrationEntries subcollection
      match /registrationEntries/{id} {
        allow read, write: if isSignedIn();
      }
      match /registrationEntries {
        allow list: if isSignedIn();
      }
      
      match /registration/{id} {
        allow read, write: if isSignedIn();
      }

      match /invites/{id} {
        allow read, write: if isSignedIn();
      }

      match /events/{id} {
        allow read, write: if isSignedIn();
      }

      match /members/{id} {
        allow read, write: if isSignedIn();
      }

      // Catch-all for any other sub-resources
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // teams and their nested operational data
    match /teams/{teamId} {
      allow read, write: if isSignedIn();
      
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- GLOBAL REPOSITORIES ---

    match /plans/{planId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /features/{featureId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /facilities/{facilityId} {
      allow read, write: if isSignedIn();
    }

    match /team_memberships/{membershipId} {
      allow read, write: if isSignedIn();
    }

    // --- PERSONAL INFRASTRUCTURE ---
    
    match /userProfiles/{userId} {
      allow read, write: if isOwner(userId);
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    match /players/{playerId} {
      allow read, write: if isSignedIn();
    }

    // --- COLLECTION GROUPS ---
    // These allow querying across all collections with the same name
    
    match /signatures/{id} { allow read, write: if isSignedIn(); }
    match /registrationEntries/{id} { allow read, write: if isSignedIn(); }
    match /members/{id} { allow read, write: if isSignedIn(); }
    match /events/{id} { allow read, write: if isSignedIn(); }
    match /files/{id} { allow read, write: if isSignedIn(); }
    match /incidents/{id} { allow read, write: if isSignedIn(); }
    match /feedPosts/{id} { allow read, write: if isSignedIn(); }
    match /groupChats/{id} { allow read, write: if isSignedIn(); }
    match /volunteers/{id} { allow read, write: if isSignedIn(); }
    match /fundraising/{id} { allow read, write: if isSignedIn(); }
    match /drills/{id} { allow read, write: if isSignedIn(); }
    match /games/{id} { allow read, write: if isSignedIn(); }
    match /equipment/{id} { allow read, write: if isSignedIn(); }

    // --- GLOBAL DEFAULT DENY ---
    match /{path=**} {
      allow read, write: if false;
    }
  }
}