rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- CORE AUTHORIZATION HELPERS ---

    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email == 'thisearlyseason@gmail.com';
    }

    // --- GLOBAL CATALOG ---
    // Publicly readable for pricing and feature selection
    match /plans/{planId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }
    
    match /features/{featureId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // --- USERS HIERARCHY ---
    match /users/{userId} {
      allow get, list, write: if isOwner(userId) || isSuperAdmin();
      
      match /{allPaths=**} {
        allow read, write: if isOwner(userId) || isSuperAdmin();
      }
    }
    
    // Sentinel for membership indexing
    match /team_memberships/{membershipId} {
      allow read, write: if isSignedIn();
    }

    // --- TEAMS HIERARCHY ---
    // Flattened hierarchy to satisfy Firestore 'List Proving' for subcollections
    match /teams/{teamId} {
      allow get, list, write: if isSignedIn(); 
      
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- LEAGUES HIERARCHY ---
    match /leagues/{leagueId} {
      allow read, write: if isSignedIn();
      
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- PLAYERS HIERARCHY ---
    match /players/{playerId} {
      allow read, write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- FACILITIES ---
    match /facilities/{facilityId} {
      allow read, write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- SUBSCRIPTIONS (Operational) ---
    match /subscriptions/{userId} {
      allow read: if isOwner(userId) || isSuperAdmin();
      allow write: if true; // Unsafe, but required for prototype webhook synchronization
    }

    // --- COLLECTION GROUP ACCESS ---
    // Required for cross-squad aggregation in Dashboard and Club hubs
    match /{path=**}/registrationEntries/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/members/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/events/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/signatures/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/files/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/incidents/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/feedPosts/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/teamMemberships/{id} { allow read, write: if isSignedIn(); }

    // --- GLOBAL DEFAULT DENY ---
    match /{path=**} {
      allow read, write: if false;
    }
  }
}