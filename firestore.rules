
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'thisearlyseason@gmail.com' ||
        request.auth.token.email == 'test@gmail.com'
      );
    }

    function isHouseholdParent(householdId) {
      return isSignedIn() && (
        request.auth.uid == householdId || 
        request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.parentIds
      );
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      match /teamMemberships/{membershipId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /households/{householdId} {
      allow read, write: if isOwner(householdId) || isHouseholdParent(householdId);
    }

    match /players/{playerId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource.data.parentId == request.auth.uid ||
        resource.data.userId == request.auth.uid ||
        isSuperAdmin()
      );
    }

    match /teams/{teamId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource.data.ownerUserId == request.auth.uid ||
        resource.data.members[request.auth.uid] == 'admin' ||
        isSuperAdmin()
      );

      // Allow public access to registration protocols for recruitment
      match /registration/{protocolId} {
        allow read: if true;
      }

      // Allow public creation of registration entries
      match /registrationEntries/{entryId} {
        allow create: if true;
        allow read, write: if isSignedIn();
      }

      match /{allSubcollections=**} {
        allow read, write: if isSignedIn();
      }
    }

    match /facilities/{facilityId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource.data.clubId == request.auth.uid ||
        isSuperAdmin()
      );
      
      match /fields/{fieldId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
    }

    match /leagues/{leagueId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource.data.creatorId == request.auth.uid ||
        isSuperAdmin()
      );
      
      // Allow public access to registration protocols for recruitment
      match /registration/{protocolId} {
        allow read: if true;
      }

      // Allow public creation of registration entries
      match /registrationEntries/{entryId} {
        allow create: if true;
        allow read, write: if isSignedIn();
      }

      match /{allSubcollections=**} {
        allow read, write: if isSignedIn();
      }
    }

    match /plans/{planId} {
      allow read: if isSignedIn();
    }

    match /features/{featureId} {
      allow read: if isSignedIn();
    }

    // Support for collectionGroup queries used in search/global views
    match /{path=**}/registrationEntries/{entryId} {
      allow read: if isSignedIn();
      allow create: if true;
      allow write: if isSignedIn();
    }
    
    match /{path=**}/events/{eventId} {
      allow read: if isSignedIn();
    }
    
    match /{path=**}/members/{memberId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/fields/{fieldId} {
      allow read: if isSignedIn();
    }
  }
}
