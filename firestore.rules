rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- CORE AUTHORIZATION HELPERS ---

    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- USERS HIERARCHY ---
    match /users/{userId} {
      allow get, list, write: if isOwner(userId);
      
      match /teamMemberships/{tid} {
        allow read, write: if isOwner(userId);
      }
      
      match /hiddenChats/{cid} {
        allow read, write: if isOwner(userId);
      }
      
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- TEAMS HIERARCHY ---
    match /teams/{teamId} {
      allow get, list, write: if isSignedIn(); 
      
      // Explicit matches for provable list operations
      match /members/{mid} { allow read, write: if isSignedIn(); }
      match /events/{eid} { allow read, write: if isSignedIn(); }
      match /games/{gid} { allow read, write: if isSignedIn(); }
      match /alerts/{aid} { allow read, write: if isSignedIn(); }
      match /feedPosts/{pid} { allow read, write: if isSignedIn(); }
      match /drills/{did} { allow read, write: if isSignedIn(); }
      match /files/{fid} { allow read, write: if isSignedIn(); }
      match /equipment/{eid} { allow read, write: if isSignedIn(); }
      match /volunteers/{vid} { allow read, write: if isSignedIn(); }
      match /fundraising/{fid} { allow read, write: if isSignedIn(); }
      match /incidents/{iid} { allow read, write: if isSignedIn(); }
      
      match /groupChats/{cid} { 
        allow read, write: if isSignedIn(); 
        match /messages/{mid} { allow read, write: if isSignedIn(); }
      }

      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- LEAGUES HIERARCHY ---
    match /leagues/{leagueId} {
      allow read, write: if isSignedIn();
      
      match /registrationEntries/{eid} { allow read, write: if isSignedIn(); }
      match /registration/{cid} { allow read, write: if isSignedIn(); }
      match /payments/{pid} { allow read, write: if isSignedIn(); }
      
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- PLAYERS HIERARCHY ---
    match /players/{playerId} {
      allow read, write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- FACILITIES ---
    match /facilities/{facilityId} {
      allow read, write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- COLLECTION GROUP ACCESS ---
    
    match /{path=**}/registrationEntries/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/members/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/events/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/signatures/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/files/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/incidents/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/feedPosts/{id} { allow read, write: if isSignedIn(); }

    // --- GLOBAL DEFAULT DENY ---
    match /{path=**} {
      allow read, write: if false;
    }
  }
}