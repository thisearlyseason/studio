
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is signed in.
    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    // Helper to check if the user is accessing their own data.
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- USER PROFILES ---
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      // Explicit match for subcollections like teamMemberships
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- PLAYER PROFILES ---
    // Authorized for all signed-in users to support recruiting search and team coordination
    match /players/{playerId} {
      allow read, write: if isSignedIn();
      
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- LEAGUES ---
    // Explicitly flat hierarchy to satisfy Firestore List Proving requirements
    match /leagues/{leagueId} {
      allow read, write: if isSignedIn();
      
      match /registration/{configId} {
        allow read, write: if isSignedIn();
      }
      
      match /registrationEntries/{entryId} {
        allow read, write: if isSignedIn();
      }

      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- TEAMS ---
    match /teams/{teamId} {
      allow read, write: if isSignedIn();
      
      match /members/{memberId} {
        allow read, write: if isSignedIn();
      }
      
      match /events/{eventId} {
        allow read, write: if isSignedIn();
      }

      match /groupChats/{chatId} {
        allow read, write: if isSignedIn();
        match /messages/{messageId} {
          allow read, write: if isSignedIn();
        }
      }

      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- FACILITIES & VENUES ---
    match /facilities/{facilityId} {
      allow read, write: if isSignedIn();
      
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- GLOBAL CATALOG & CONFIG ---
    // Publicly readable for pricing and capability matrix initialization
    match /plans/{planId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /features/{featureId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // --- SUBSCRIPTIONS ---
    match /subscriptions/{userId} {
      allow read: if isOwner(userId);
      allow write: if isSignedIn();
    }
  }
}
