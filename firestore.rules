rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAnonymous() {
      return isSignedIn() && request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    // Check membership via memberships collection
    function isTeamMember(teamId) {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/team_memberships/$(teamId + "_" + request.auth.uid)) ||
        exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid))
      );
    }

    // Check admin via membership doc or team ownership
    function isTeamAdmin(teamId) {
      return isSignedIn() && (
        get(/databases/$(database)/documents/team_memberships/$(teamId + "_" + request.auth.uid)).data.role == 'Admin' ||
        get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUserId == request.auth.uid ||
        get(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid)).data.role == 'Admin'
      );
    }

    // --- User Profiles ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isAnonymous();
      
      match /{allPaths=**} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId) || isAnonymous();
      }
    }

    // --- Players ---
    match /players/{playerId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() || isAnonymous();
      
      match /{allPaths=**} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() || isAnonymous();
      }
    }

    // --- Teams ---
    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() || isAnonymous();
      allow update, delete: if isTeamAdmin(teamId) || isAnonymous();

      match /{allPaths=**} {
        allow read: if isSignedIn();
        allow write: if isTeamAdmin(teamId) || isTeamMember(teamId) || isAnonymous();
      }
    }

    // --- Team Memberships ---
    match /team_memberships/{membershipId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() || isAnonymous();
    }

    // --- Facilities ---
    match /facilities/{facId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() || isAnonymous();
      
      match /{allPaths=**} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() || isAnonymous();
      }
    }

    // --- Leagues ---
    match /leagues/{leagueId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() || isAnonymous();
      allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.creatorId || isSuperAdmin()) || isAnonymous();
      
      match /{allPaths=**} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() || isAnonymous();
      }
    }

    function isSuperAdmin() {
      return request.auth.token.email == 'thisearlyseason@gmail.com';
    }

    // --- Global Catalog ---
    match /plans/{planId} {
      allow read: if true;
    }
    match /features/{featureId} {
      allow read: if true;
    }

    // --- Collection Groups ---
    match /{path=**}/events/{eventId} {
      allow read: if isSignedIn();
    }
    match /{path=**}/files/{fileId} {
      allow read: if isSignedIn();
    }
    match /{path=**}/signatures/{sigId} {
      allow read: if isSignedIn();
    }
    match /{path=**}/registrationEntries/{entryId} {
      allow read: if isSignedIn();
    }
    match /{path=**}/members/{memberId} {
      allow read: if isSignedIn();
    }
    match /{path=**}/feedPosts/{postId} {
      allow read: if isSignedIn();
    }

    // Explicitly deny root document listing
    match / {
      allow list: if false;
    }

    // Deny by default
    match /{path=**} {
      allow read, write: if false;
    }
  }
}