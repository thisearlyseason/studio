rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SquadForge Security Rules
     * Optimized for reliability and performance using parent-based authorization
     * for sub-collections, which avoids denormalization issues.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Helper to get the parent team document. 
    // Using get() in rules is robust for sub-collections and query-aware.
    function getTeam(teamId) {
      return get(/databases/$(database)/documents/teams/$(teamId)).data;
    }

    function isMemberOfTeam(teamId) {
      return isSignedIn() && 
             getTeam(teamId).members != null && 
             getTeam(teamId).members[request.auth.uid] != null;
    }

    function isAdminOfTeam(teamId) {
      return isSignedIn() && 
             getTeam(teamId).members != null && 
             getTeam(teamId).members[request.auth.uid] == 'Admin';
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get, create, update: if isSignedIn() && request.auth.uid == userId;
      allow list: if false;
    }

    match /teams/{teamId} {
      // Top-level teams collection. Listable only if you are in the members map.
      // The query must include where("members." + uid, "!=", null) or similar.
      allow list: if isSignedIn() && resource.data.members[request.auth.uid] != null;
      allow get: if isSignedIn() && resource.data.members[request.auth.uid] != null;
      allow create: if isSignedIn() && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.members[request.auth.uid] == 'Admin';

      // --- Sub-collections ---
      // These rules use parent-based checks which are extremely reliable for list queries.

      match /members/{memberId} {
        allow list, get: if isMemberOfTeam(teamId);
        allow create, update, delete: if isAdminOfTeam(teamId);
      }

      match /feedPosts/{postId} {
        allow list, get: if isMemberOfTeam(teamId);
        allow create: if isMemberOfTeam(teamId);
        allow update, delete: if isAdminOfTeam(teamId) || (resource != null && resource.data.authorId == request.auth.uid);

        match /comments/{commentId} {
          allow list, get: if isMemberOfTeam(teamId);
          allow create: if isMemberOfTeam(teamId);
          allow update, delete: if isAdminOfTeam(teamId) || (resource != null && resource.data.authorId == request.auth.uid);
        }
      }

      match /events/{eventId} {
        allow list, get: if isMemberOfTeam(teamId);
        allow create, update, delete: if isAdminOfTeam(teamId);
      }

      match /games/{gameId} {
        allow list, get: if isMemberOfTeam(teamId);
        allow create, update, delete: if isAdminOfTeam(teamId);
      }

      match /alerts/{alertId} {
        allow list, get: if isMemberOfTeam(teamId);
        allow create, update, delete: if isAdminOfTeam(teamId);
      }

      match /files/{fileId} {
        allow list, get: if isMemberOfTeam(teamId);
        allow create: if isMemberOfTeam(teamId);
        allow update, delete: if isAdminOfTeam(teamId) || (resource != null && resource.data.uploadedBy == request.auth.uid);
      }

      match /groupChats/{chatId} {
        allow list, get: if isMemberOfTeam(teamId);
        allow create: if isMemberOfTeam(teamId);
        allow update, delete: if isAdminOfTeam(teamId);

        match /messages/{messageId} {
          allow list, get: if isMemberOfTeam(teamId);
          allow create: if isMemberOfTeam(teamId);
          allow update, delete: if isAdminOfTeam(teamId) || (resource != null && resource.data.authorId == request.auth.uid);
        }
      }
    }
  }
}