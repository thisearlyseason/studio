
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is signed in.
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check if the user is the owner of the document.
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // --- USER PROFILES ---
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      match /teamMemberships/{membershipId} {
        allow read, write: if isOwner(userId);
      }
      match /hiddenChats/{chatId} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- PLAYER PROFILES ---
    // Secures player data for both adult players and minor children.
    match /players/{playerId} {
      allow read, write: if isSignedIn();
      
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- LEAGUES ---
    // Allows coordinated access to league standings and registration entries.
    match /leagues/{leagueId} {
      allow read, write: if isSignedIn();
      
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- TEAMS ---
    // Allows squad-level coordination including feed, roster, and events.
    match /teams/{teamId} {
      allow read, write: if isSignedIn();
      
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- FACILITIES & VENUES ---
    match /facilities/{facilityId} {
      allow read, write: if isSignedIn();
      
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- GLOBAL CATALOG & CONFIG ---
    // Plans and features are publicly readable for pricing and initialization.
    match /plans/{planId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /features/{featureId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // --- SUBSCRIPTIONS ---
    match /subscriptions/{userId} {
      allow read: if isSignedIn() && isOwner(userId);
      allow write: if true; // Authorized for synchronization via secure endpoints
    }
  }
}
