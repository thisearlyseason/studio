
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- CORE HELPERS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isDemoId(id) {
      return id != null && id.size() >= 5 && id[0:5] == "demo_";
    }

    function isOwner(teamId) {
      return isSignedIn() && (
        get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUserId == request.auth.uid ||
        isDemoId(teamId)
      );
    }

    // --- USER PROFILES ---
    match /users/{userId} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isDemoId(userId));
      
      match /teamMemberships/{mId} {
        allow read, write: if isSignedIn() && (request.auth.uid == userId || isDemoId(userId));
      }
    }

    // --- SUBSCRIPTIONS ---
    match /subscriptions/{subscriptionId} {
      allow read, write: if isSignedIn();
    }

    // --- PLAYERS (Family Hub) ---
    match /players/{playerId} {
      // Allow authenticated users to list/get player profiles. 
      // Query filters in the app handle privacy (guardianId check).
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (
        isDemoId(playerId) || 
        request.resource.data.guardianId == request.auth.uid ||
        request.resource.data.userId == request.auth.uid
      );
    }

    // --- LEAGUES ---
    match /leagues/{leagueId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (
        resource == null || 
        resource.data.creatorId == request.auth.uid || 
        isDemoId(leagueId)
      );

      match /registration/config {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }

      match /registrationEntries/{entryId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn();
      }
    }

    // --- TEAMS & SUBCOLLECTIONS ---
    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isOwner(teamId) || isDemoId(teamId));

      match /members/{mId} { allow read: if isSignedIn(); allow write: if isSignedIn(); }
      match /events/{eId} { allow read: if isSignedIn(); allow write: if isSignedIn(); }
      match /games/{gId} { allow read: if isSignedIn(); allow write: if isSignedIn(); }
      match /drills/{dId} { allow read: if isSignedIn(); allow write: if isSignedIn(); }
      match /files/{fId} { allow read: if isSignedIn(); allow write: if isSignedIn(); }
      match /alerts/{aId} { allow read: if isSignedIn(); allow write: if isSignedIn(); }
      match /volunteers/{vId} { allow read: if isSignedIn(); allow write: if isSignedIn(); }
      match /fundraising/{fId} { allow read: if isSignedIn(); allow write: if isSignedIn(); }
      
      match /groupChats/{cId} { 
        allow read, write: if isSignedIn(); 
        match /messages/{msgId} { allow read, write: if isSignedIn(); }
      }
      
      match /feedPosts/{pId} { 
        allow read, write: if isSignedIn();
        match /comments/{cId} { allow read, write: if isSignedIn(); }
      }
    }

    // --- ORGANIZATIONS ---
    match /organizations/{orgId} {
      allow read, write: if isSignedIn();
      match /facilities/{fId} { allow read, write: if isSignedIn(); }
    }

    // --- TOURNAMENTS ---
    match /tournaments/{tourneyId} {
      allow read, write: if isSignedIn();
    }

    match /matches/{matchId} {
      allow read, write: if isSignedIn();
    }

    // --- COLLECTION GROUPS ---
    match /{path=**}/members/{mId} { allow read: if isSignedIn(); }
    match /{path=**}/events/{eId} { allow read: if isSignedIn(); }
    match /{path=**}/alerts/{aId} { allow read: if isSignedIn(); }
    match /{path=**}/registrationEntries/{eId} { allow read: if isSignedIn(); }
  }
}
