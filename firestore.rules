
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // HELPER FUNCTIONS
    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.get('email', '') == 'thisearlyseason@gmail.com' || 
        request.auth.token.get('email', '') == 'test@gmail.com'
      );
    }

    function isDemoTeam(teamId) {
      return teamId.matches('^demo_.*');
    }

    function isTeamMember(teamId) {
      return isSignedIn() && (
        isDemoTeam(teamId) || 
        isSuperAdmin() ||
        exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid))
      );
    }

    function isTeamAdmin(teamId) {
      return isSignedIn() && (
        isDemoTeam(teamId) ||
        isSuperAdmin() ||
        (exists(/databases/$(database)/documents/teams/$(teamId)) && (
          get(/databases/$(database)/documents/teams/$(teamId)).data.get('ownerUserId', '') == request.auth.uid ||
          (exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid)).data.get('role', '') == 'Admin')
        ))
      );
    }

    match /leagues {
      allow list: if isSignedIn();
    }

    match /leagues/{leagueId} {
      allow get, create, update, delete: if isSignedIn();
      
      match /registration/config {
        allow read: if true;
        allow write: if isSuperAdmin() || (isSignedIn() && get(/databases/$(database)/documents/leagues/$(leagueId)).data.creatorId == request.auth.uid);
      }
      
      match /registrationEntries/{entryId} {
        allow list, get: if isSignedIn() && (
          isSuperAdmin() || 
          isDemoTeam(leagueId) ||
          get(/databases/$(database)/documents/leagues/$(leagueId)).data.creatorId == request.auth.uid ||
          (resource != null && resource.data.assigned_team_owner_id == request.auth.uid)
        );
        allow create: if true; // Public enrollment
        allow update, delete: if isSuperAdmin() || (isSignedIn() && get(/databases/$(database)/documents/leagues/$(leagueId)).data.creatorId == request.auth.uid);
      }
    }

    match /leagues/global/invites/{inviteId} {
      // Users can only see invites sent to their specific email
      allow list, get: if isSignedIn() && (
        isSuperAdmin() || 
        (request.auth.token.get('email', '') != '' && resource.data.invitedEmail == request.auth.token.email)
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }

    // CLUBS & ORGANIZATIONS
    match /clubs/{clubId} {
      allow read, write: if isSignedIn();
    }

    // PAYMENTS LEDGER
    match /payments/{paymentId} {
      allow read, write: if isSignedIn();
    }

    // TEAMS HUB
    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isTeamAdmin(teamId);

      match /volunteers/{oppId} {
        allow read: if isSignedIn() && (isTeamMember(teamId) || isTeamAdmin(teamId));
        allow create, delete: if isTeamAdmin(teamId);
        allow update: if isSignedIn() && (isTeamMember(teamId) || isTeamAdmin(teamId));
      }

      match /fundraising/{fundId} {
        allow read: if isSignedIn() && (isTeamMember(teamId) || isTeamAdmin(teamId));
        allow create, delete: if isTeamAdmin(teamId);
        allow update: if isSignedIn() && (isTeamMember(teamId) || isTeamAdmin(teamId));
      }

      match /members/{memberId} {
        allow read: if isSignedIn();
        allow write: if isTeamAdmin(teamId) || isOwner(memberId);
      }

      match /groupChats/{chatId} {
        allow list, get: if isSignedIn() && (isDemoTeam(teamId) || isTeamMember(teamId));
        allow create: if isTeamMember(teamId);
        allow update: if isTeamMember(teamId) && (isTeamAdmin(teamId) || request.auth.uid in resource.data.memberIds);
        
        match /messages/{messageId} {
          allow read: if isTeamMember(teamId);
          allow create: if isTeamMember(teamId);
          allow update: if isTeamMember(teamId);
        }
      }
      
      match /events/{eventId} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId);
        
        match /registrations/{regId} {
          allow list, get: if isTeamMember(teamId);
          allow create: if true;
          allow update, delete: if isTeamAdmin(teamId);
        }
      }

      match /games/{gameId} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId);
      }
      
      match /drills/{drillId} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId);
      }

      match /files/{fileId} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId);
      }

      match /alerts/{alertId} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId);
      }

      match /feedPosts/{postId} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId);
        
        match /comments/{commentId} {
          allow read: if isTeamMember(teamId);
          allow create: if isTeamMember(teamId);
          allow delete: if isTeamAdmin(teamId) || resource.data.authorId == request.auth.uid;
        }
      }
    }

    match /users/{userId} {
      allow read, update, delete: if isOwner(userId) || isSuperAdmin();
      allow create: if isSignedIn(); 
      
      match /teamMemberships/{membershipId} {
        allow read: if isOwner(userId) || isSuperAdmin();
        allow write: if isOwner(userId) || isSuperAdmin();
      }
    }

    // COLLECTION GROUPS - FOR HUB AGGREGATION
    match /{path=**}/members/{memberId} { allow read: if isSignedIn(); }
    match /{path=**}/events/{eventId} { allow read: if isSignedIn(); }
    match /{path=**}/alerts/{alertId} { allow read: if isSignedIn(); }
    match /{path=**}/registrationEntries/{entryId} { allow read: if isSignedIn(); }

    match /players/{playerId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.parentId == request.auth.uid || isSuperAdmin());
    }

    match /plans/{planId} { allow get, list: if true; }
    match /features/{featureId} { allow get, list: if true; }
    match /leads/{leadId} { allow create: if true; }
  }
}
