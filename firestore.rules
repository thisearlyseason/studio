rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SQUADFORGE SECURITY RULES
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    /** Hardcoded Super Admin check for administrative UIDs provided in console errors. */
    function isSuperAdmin() {
      return isSignedIn() && request.auth.uid in ['ai2QThECAwfkAFw608m7TgPZTmk2', 'super-admin-uid-placeholder'];
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** Verifies a user's membership in a specific team via the denormalized path. */
    function isTeamMember(teamId) {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)/teamMemberships/$(teamId));
    }

    /** Verifies if the user is an Admin of a specific team. */
    function isTeamAdmin(teamId) {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)/teamMemberships/$(teamId)).data.role == 'Admin';
    }

    function isChatMember(chatData) {
      return isSignedIn() && (request.auth.uid in chatData.memberIds);
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSuperAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);

      match /teamMemberships/{teamId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isExistingOwner(userId);
        allow delete: if isExistingOwner(userId);
      }

      match /hiddenChats/{chatId} {
        allow get, list: if isOwner(userId);
        allow create, update, delete: if isOwner(userId);
      }
    }

    match /teams/{teamId} {
      allow get: if isSuperAdmin() || isTeamMember(teamId);
      allow list: if isSuperAdmin();
      allow create: if isSignedIn();
      allow update, delete: if resource != null && (isSuperAdmin() || isTeamAdmin(teamId));

      match /members/{memberId} {
        allow read: if isSuperAdmin() || isTeamMember(teamId);
        allow create, update, delete: if isSuperAdmin() || isTeamAdmin(teamId);
      }

      match /feedPosts/{postId} {
        allow read: if isSuperAdmin() || isTeamMember(teamId);
        allow create: if isTeamMember(teamId);
        allow update, delete: if isSuperAdmin() || (isTeamMember(teamId) && (isExistingOwner(resource.data.authorId) || isTeamAdmin(teamId)));

        match /comments/{commentId} {
          allow read: if isSuperAdmin() || isTeamMember(teamId);
          allow create: if isTeamMember(teamId);
          allow update, delete: if isSuperAdmin() || (isTeamMember(teamId) && (isExistingOwner(resource.data.authorId) || isTeamAdmin(teamId)));
        }
      }

      match /events/{eventId} {
        allow read: if isSuperAdmin() || isTeamMember(teamId);
        allow create, update, delete: if isSuperAdmin() || isTeamAdmin(teamId);

        match /rsvps/{userId} {
          allow read: if isSuperAdmin() || isTeamMember(teamId);
          allow create, update, delete: if isOwner(userId);
        }
      }

      match /games/{gameId} {
        allow read: if isSuperAdmin() || isTeamMember(teamId);
        allow create, update, delete: if isSuperAdmin() || isTeamAdmin(teamId);
      }

      match /drills/{drillId} {
        allow read: if isSuperAdmin() || isTeamMember(teamId);
        allow create, update, delete: if isSuperAdmin() || isTeamAdmin(teamId);
      }

      match /files/{fileId} {
        allow read: if isSuperAdmin() || isTeamMember(teamId);
        allow create: if isTeamMember(teamId);
        allow update, delete: if isSuperAdmin() || isTeamAdmin(teamId) || isExistingOwner(resource.data.uploadedBy);
      }

      match /groupChats/{chatId} {
        allow get, list: if isSuperAdmin() || isTeamMember(teamId);
        allow create: if isTeamMember(teamId);
        allow update: if isSuperAdmin() || (isTeamMember(teamId) && isChatMember(resource.data));
        allow delete: if isSuperAdmin() || isTeamAdmin(teamId);

        match /messages/{messageId} {
          allow read: if isSuperAdmin() || isTeamMember(teamId);
          allow create: if isTeamMember(teamId);
          allow update, delete: if isSuperAdmin() || isExistingOwner(resource.data.authorId);
        }
      }

      match /alerts/{alertId} {
        allow read: if isSuperAdmin() || isTeamMember(teamId);
        allow create, update, delete: if isSuperAdmin() || isTeamAdmin(teamId);
      }
    }
  }
}