
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- CORE AUTHORIZATION HELPERS ---

    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'thisearlyseason@gmail.com' || 
        request.auth.uid == '3Dybqi6vkHNUQQM66jiEZWfmwsW2' ||
        request.auth.uid == 'wnvOuvwmoUhS5U4kdaBrZz7tGbF3'
      );
    }

    // --- GLOBAL CATALOG ---
    // Provable flattening: Allow all to read pricing and features
    match /plans/{id} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
    
    match /features/{id} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // --- LEAGUES HIERARCHY ---
    // Explicit subcollection matching for list proving
    match /leagues/{leagueId} {
      allow read, write: if isSignedIn();
    }
    
    match /leagues/{leagueId}/registrationEntries/{entryId} {
      allow read, write: if isSignedIn();
    }
    
    match /leagues/{leagueId}/registration/{configId} {
      allow read, write: if isSignedIn();
    }

    match /leagues/{leagueId}/payments/{paymentId} {
      allow read, write: if isSignedIn();
    }

    // --- TEAMS HIERARCHY ---
    match /teams/{teamId} {
      allow read, write: if isSignedIn();
    }
    
    match /teams/{teamId}/members/{userId} {
      allow read, write: if isSignedIn();
    }

    match /teams/{teamId}/alerts/{alertId} {
      allow read, write: if isSignedIn();
    }

    match /teams/{teamId}/feedPosts/{postId} {
      allow read, write: if isSignedIn();
    }
    
    match /teams/{teamId}/feedPosts/{postId}/comments/{commentId} {
      allow read, write: if isSignedIn();
    }

    match /teams/{teamId}/events/{eventId} {
      allow read, write: if isSignedIn();
    }
    
    match /teams/{teamId}/events/{eventId}/registrations/{regId} {
      allow read, write: if isSignedIn();
    }
    
    match /teams/{teamId}/incidents/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /teams/{teamId}/files/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /teams/{teamId}/equipment/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /teams/{teamId}/volunteers/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /teams/{teamId}/fundraising/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /teams/{teamId}/groupChats/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /teams/{teamId}/drills/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /teams/{teamId}/games/{id} {
      allow read, write: if isSignedIn();
    }

    // --- USERS HIERARCHY ---
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isSuperAdmin();
    }
    
    match /users/{userId}/teamMemberships/{teamId} {
      allow read, write: if isOwner(userId) || isSuperAdmin();
    }
    
    match /users/{userId}/hiddenChats/{chatId} {
      allow read, write: if isOwner(userId) || isSuperAdmin();
    }

    // --- PLAYERS HIERARCHY ---
    match /players/{playerId} {
      allow read, write: if isSignedIn();
    }
    
    match /players/{playerId}/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    // --- FACILITIES ---
    match /facilities/{facilityId} {
      allow read, write: if isSignedIn();
    }
    
    match /facilities/{facilityId}/fields/{fieldId} {
      allow read, write: if isSignedIn();
    }

    // --- COLLECTION GROUP ACCESS ---
    // Satisfies aggregated queries for Club Hub and Family Hub
    match /{path=**}/registrationEntries/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/members/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/events/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/signatures/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/files/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/incidents/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/feedPosts/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/teamMemberships/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/groupChats/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/alerts/{id} { allow read, write: if isSignedIn(); }

    // --- GLOBAL DEFAULT DENY ---
    match /{path=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
