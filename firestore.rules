rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Helper to check if a user is a member of a team
    function isTeamMember(teamId) {
      return isSignedIn() && exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid));
    }

    // Helper to check if a user is an admin of a team
    function isTeamAdmin(teamId) {
      let member = get(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid));
      return isSignedIn() && member.data.role == 'Admin';
    }

    // --- User Profiles ---
    match /userProfiles/{userId} {
      allow read: if isSignedIn(); // Allow reading other members for rosters
      allow write: if isOwner(userId);
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
      
      match /teamMemberships/{membershipId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
      
      match /hiddenChats/{chatId} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- Teams ---
    match /teams/{teamId} {
      allow read: if isSignedIn(); // Allow code validation
      allow create: if isSignedIn();
      allow update, delete: if isTeamAdmin(teamId);

      match /members/{memberId} {
        allow read: if isTeamMember(teamId);
        // Admins can edit anyone, members only themselves
        allow create: if isSignedIn(); 
        allow update: if isTeamAdmin(teamId) || isOwner(memberId);
        allow delete: if isTeamAdmin(teamId);
      }

      match /events/{eventId} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId);
        
        match /registrations/{regId} {
          allow read: if isTeamAdmin(teamId);
          allow create: if true; // Public registration
        }
      }

      match /feedPosts/{postId} {
        allow read: if isTeamMember(teamId);
        allow create: if isTeamMember(teamId);
        allow update: if isTeamMember(teamId) && (request.auth.uid == resource.data.authorId || isTeamAdmin(teamId));
        allow delete: if isTeamAdmin(teamId) || (isSignedIn() && request.auth.uid == resource.data.authorId);

        match /comments/{commentId} {
          allow read: if isTeamMember(teamId);
          allow create: if isTeamMember(teamId);
          allow delete: if isTeamAdmin(teamId) || (isSignedIn() && request.auth.uid == resource.data.authorId);
        }
      }

      match /groupChats/{chatId} {
        allow read: if isSignedIn() && request.auth.uid in resource.data.memberIds;
        allow create: if isTeamMember(teamId);
        allow update: if isSignedIn() && (request.auth.uid in resource.data.memberIds || isTeamAdmin(teamId));
        allow delete: if isTeamAdmin(teamId);

        match /messages/{messageId} {
          allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)/groupChats/$(chatId)).data.memberIds;
          allow create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)/groupChats/$(chatId)).data.memberIds;
          allow update, delete: if isSignedIn() && request.auth.uid == resource.data.authorId;
        }
      }

      match /files/{fileId} {
        allow read: if isTeamMember(teamId);
        allow create: if isTeamMember(teamId);
        allow delete: if isTeamAdmin(teamId) || (isSignedIn() && request.auth.uid == resource.data.uploadedBy);
      }

      match /drills/{drillId} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId);
      }

      match /games/{gameId} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId);
      }

      match /volunteers/{oppId} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId) || isTeamMember(teamId); // Signups are writes
      }

      match /fundraising/{fundId} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId) || isTeamMember(teamId);
        
        match /donations/{donId} {
          allow read: if isTeamAdmin(teamId);
          allow create: if true; // Public donations
          allow update: if isTeamAdmin(teamId);
        }
      }

      match /equipment/{eqId} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId);
      }

      match /incidents/{incId} {
        allow read, write: if isTeamAdmin(teamId);
      }
      
      match /alerts/{alertId} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId);
      }
    }

    // --- Players ---
    match /players/{playerId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid == resource.data.parentId || request.auth.uid == resource.data.userId);
      
      match /recruitingProfile/{docId} {
        allow read: if true; // Public scouting
        allow write: if isSignedIn();
      }
      
      match /evaluations/{evalId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
      
      match /videos/{videoId} {
        allow read: if true;
        allow write: if isSignedIn();
      }
    }

    // --- Facilities ---
    match /facilities/{facId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
      
      match /fields/{fieldId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
    }

    // --- Leagues ---
    match /leagues/{leagueId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && request.auth.uid == resource.data.creatorId;
      
      match /registration/{docId} {
        allow read: if true;
        allow write: if isSignedIn();
      }
      
      match /registrationEntries/{entryId} {
        allow read: if isSignedIn();
        allow create: if true;
        allow update: if isSignedIn();
      }
      
      match /payments/{payId} {
        allow read, write: if isSignedIn();
      }
    }

    match /leagues/global/invites/{inviteId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    // --- Global Catalog ---
    match /plans/{planId} {
      allow read: if true;
    }
    match /features/{featureId} {
      allow read: if true;
    }

    // --- Collection Groups ---
    match /{path=**}/events/{eventId} {
      allow read: if isSignedIn();
    }
    match /{path=**}/files/{fileId} {
      allow read: if isSignedIn();
    }
    match /{path=**}/signatures/{sigId} {
      allow read: if isSignedIn();
    }
    match /{path=**}/registrationEntries/{entryId} {
      allow read: if isSignedIn();
    }
    match /{path=**}/members/{memberId} {
      allow read: if isSignedIn();
    }

    // Catch-all
    match /{path=**} {
      allow read, write: if false;
    }
  }
}