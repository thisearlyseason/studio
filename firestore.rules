
/**
 * SquadForge Firestore Security Rules
 *
 * CORE PHILOSOPHY:
 * This ruleset implements a robust, role-based and ownership-based security model.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the user is an application administrator (Super Admin).
     */
    function isAdmin() {
      // In this prototype, we treat specific emails as super-admins for seeding and global config.
      return isSignedIn() && (request.auth.token.email == 'thisearlyseason@gmail.com' || request.auth.token.email == 'test@gmail.com');
    }

    /**
     * @description Checks if the user is an admin of a specific team.
     */
    function isTeamAdmin(teamId) {
      let teamData = get(/databases/$(database)/documents/teams/$(teamId)).data;
      return isAdmin() || (isSignedIn() && (teamData.members[request.auth.uid] == 'Admin' || teamData.createdBy == request.auth.uid || teamData.isDemo == true));
    }

    // --- COLLECTION RULES ---

    /**
     * @description Personal user account data.
     */
    match /users/{userId} {
      allow get, list, create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      
      match /teamMemberships/{membershipId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    /**
     * @description Team entities and their nested sub-resources.
     */
    match /teams/{teamId} {
      allow get, list, create: if isSignedIn();
      allow update, delete: if isTeamAdmin(teamId);

      match /members/{memberId} {
        allow read: if isSignedIn();
        allow write: if isTeamAdmin(teamId) || isOwner(request.resource.data.userId);
      }

      match /events/{eventId} {
        allow read: if isSignedIn();
        allow write: if isTeamAdmin(teamId);

        match /registrations/{regId} {
          allow read: if isTeamAdmin(teamId);
          allow create: if true;
          allow delete: if isTeamAdmin(teamId);
        }
      }

      match /games/{gameId} {
        allow read: if isSignedIn();
        allow write: if isTeamAdmin(teamId);
      }

      match /drills/{drillId} {
        allow read: if isSignedIn();
        allow write: if isTeamAdmin(teamId);
      }

      match /files/{fileId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow delete: if isTeamAdmin(teamId) || isOwner(resource.data.uploaderId);
      }

      match /alerts/{alertId} {
        allow read: if isSignedIn();
        allow create, delete: if isTeamAdmin(teamId);
      }

      match /feedPosts/{postId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isTeamAdmin(teamId) || isOwner(resource.data.authorId);

        match /comments/{commentId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn();
          allow delete: if isTeamAdmin(teamId) || isOwner(resource.data.authorId);
        }
      }

      match /groupChats/{chatId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn();
        allow delete: if isTeamAdmin(teamId);

        match /messages/{messageId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn();
          allow delete: if isTeamAdmin(teamId) || isOwner(resource.data.authorId);
        }
      }
    }

    /**
     * @description Global application configuration.
     */
    match /features/{featureId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /plans/{planId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /leads/{leadId} {
      allow create: if isSignedIn();
      allow read, write: if isAdmin();
    }
  }
}
