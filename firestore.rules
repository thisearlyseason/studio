
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isHouseholdParent(householdId) {
      return isSignedIn() && (
        request.auth.uid == householdId || 
        request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.parentIds
      );
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      match /{document=**} {
        allow read, write: if isOwner(userId);
      }
    }

    match /households/{householdId} {
      allow read, write: if isOwner(householdId) || isHouseholdParent(householdId);
    }

    match /players/{playerId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (
        resource == null || 
        resource.data.parentId == request.auth.uid
      );
    }

    match /teams/{teamId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource.data.members[request.auth.uid] == 'admin' || 
        resource.data.ownerUserId == request.auth.uid
      );

      match /{allSubcollections=**} {
        allow read, write: if isSignedIn();
      }
    }

    match /plans/{planId} {
      allow read: if isSignedIn();
    }

    match /features/{featureId} {
      allow read: if isSignedIn();
    }
  }
}
