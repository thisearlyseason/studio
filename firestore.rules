
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow read, write: if isSignedIn();
      match /teamMemberships/{mId} { allow read, write: if isSignedIn(); }
    }

    match /subscriptions/{subId} {
      allow read, write: if isSignedIn();
    }

    match /teams/{teamId} {
      allow read, write: if isSignedIn();
      match /members/{mId} { allow read, write: if isSignedIn(); }
      match /events/{eId} { allow read, write: if isSignedIn(); }
      match /games/{gId} { allow read, write: if isSignedIn(); }
      match /groupChats/{cId} { 
        allow read, write: if isSignedIn(); 
        match /messages/{msgId} { allow read, write: if isSignedIn(); }
      }
      match /files/{fId} { allow read, write: if isSignedIn(); }
      match /drills/{dId} { allow read, write: if isSignedIn(); }
      match /alerts/{aId} { allow read, write: if isSignedIn(); }
      match /volunteers/{vId} { allow read, write: if isSignedIn(); }
      match /fundraising/{fId} { allow read, write: if isSignedIn(); }
      match /feedPosts/{pId} { 
        allow read, write: if isSignedIn();
        match /comments/{cId} { allow read, write: if isSignedIn(); }
      }
    }

    match /organizations/{orgId} {
      allow read, write: if isSignedIn();
      match /facilities/{fId} { allow read, write: if isSignedIn(); }
    }

    match /leagues/{leagueId} {
      allow read, write: if isSignedIn();
      match /registration/config { allow read, write: if isSignedIn(); }
      match /registrationEntries/{eId} { allow read, write: if isSignedIn(); }
    }

    match /tournaments/{tourneyId} {
      allow read, write: if isSignedIn();
    }

    match /matches/{matchId} {
      allow read, write: if isSignedIn();
    }

    match /players/{pId} { allow read, write: if isSignedIn(); }
    match /plans/{pId} { allow read: if true; }
    match /features/{fId} { allow read: if true; }
    
    // Collection group helpers
    match /{path=**}/members/{mId} { allow read: if isSignedIn(); }
    match /{path=**}/events/{eId} { allow read: if isSignedIn(); }
    match /{path=**}/alerts/{aId} { allow read: if isSignedIn(); }
    match /{path=**}/registrationEntries/{eId} { allow read: if isSignedIn(); }
  }
}
