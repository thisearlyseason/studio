rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- TACTICAL HELPERS ---

    // Basic authentication check
    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    // Ownership check for private profiles
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Hardened check for demo/guest sessions (custom providers)
    function isAnonymous() {
      return isSignedIn() && (
        request.auth.token.firebase.sign_in_provider == 'anonymous' || 
        request.auth.token.firebase.sign_in_provider == 'custom' ||
        request.auth.token.sign_in_provider == 'anonymous' ||
        request.auth.token.sign_in_provider == 'custom'
      );
    }

    // --- INSTITUTIONAL HIERARCHY: LEAGUES ---
    
    // Explicit list permission for the root collection to satisfy 'List Proving'
    match /leagues {
      allow list: if isSignedIn();
    }

    match /leagues/{leagueId} {
      allow get: if isSignedIn();
      allow write: if isSignedIn();
      
      // Explicit matches for subcollections frequently queried
      match /invites { allow list: if isSignedIn(); }
      match /invites/{id} { allow read, write: if isSignedIn(); }
      
      match /registration { allow list: if isSignedIn(); }
      match /registration/{id} { allow read, write: if isSignedIn(); }
      
      match /registrationEntries { allow list: if isSignedIn(); }
      match /registrationEntries/{id} { allow read, write: if isSignedIn(); }

      match /payments { allow list: if isSignedIn(); }
      match /payments/{id} { allow read, write: if isSignedIn(); }

      // Recursive safety for all nested data
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- TACTICAL HIERARCHY: TEAMS ---
    
    match /teams {
      allow list: if isSignedIn();
    }

    match /teams/{teamId} {
      allow get: if isSignedIn();
      allow write: if isSignedIn();
      
      // Explicit matches for subcollections frequently queried
      match /members { allow list: if isSignedIn(); }
      match /members/{id} { allow read, write: if isSignedIn(); }
      
      match /games { allow list: if isSignedIn(); }
      match /games/{id} { allow read, write: if isSignedIn(); }
      
      match /events { allow list: if isSignedIn(); }
      match /events/{id} { allow read, write: if isSignedIn(); }
      
      match /files { allow list: if isSignedIn(); }
      match /files/{id} { allow read, write: if isSignedIn(); }

      match /drills { allow list: if isSignedIn(); }
      match /drills/{id} { allow read, write: if isSignedIn(); }

      match /alerts { allow list: if isSignedIn(); }
      match /alerts/{id} { allow read, write: if isSignedIn(); }

      match /equipment { allow list: if isSignedIn(); }
      match /equipment/{id} { allow read, write: if isSignedIn(); }

      match /incidents { allow list: if isSignedIn(); }
      match /incidents/{id} { allow read, write: if isSignedIn(); }

      match /fundraising { allow list: if isSignedIn(); }
      match /fundraising/{id} { allow read, write: if isSignedIn(); }

      match /volunteers { allow list: if isSignedIn(); }
      match /volunteers/{id} { allow read, write: if isSignedIn(); }

      match /feedPosts { allow list: if isSignedIn(); }
      match /feedPosts/{id} { allow read, write: if isSignedIn(); }

      match /groupChats { allow list: if isSignedIn(); }
      match /groupChats/{id} { allow read, write: if isSignedIn(); }
      
      // Recursive safety for nested squad data (messages, comments, etc.)
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- PERSONAL INFRASTRUCTURE: USER PROFILES ---
    
    match /userProfiles/{userId} {
      allow read, write: if isOwner(userId);
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      // Team membership listings under user doc
      match /teamMemberships { allow list: if isOwner(userId); }
      match /teamMemberships/{tid} { allow read, write: if isOwner(userId); }
      
      match /hiddenChats { allow list: if isOwner(userId); }
      match /hiddenChats/{cid} { allow read, write: if isOwner(userId); }

      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- GLOBAL ATHLETE REPOSITORY ---
    
    match /players {
      allow list: if isSignedIn();
    }

    match /players/{playerId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- PHYSICAL INFRASTRUCTURE: FACILITIES ---
    
    match /facilities {
      allow list: if isSignedIn();
    }

    match /facilities/{facilityId} {
      allow read, write: if isSignedIn();
      
      match /fields { allow list: if isSignedIn(); }
      match /fields/{id} { allow read, write: if isSignedIn(); }

      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- GLOBAL ECONOMY: BILLING PLANS ---
    
    match /plans {
      allow list: if true;
    }

    match /plans/{planId} {
      allow read: if true;
      allow write: if false;
    }

    // --- CROSS-SQUAD AGGREGATION (COLLECTION GROUPS) ---
    // Necessary for 'Master Intelligence' household/club aggregate views
    
    match /{path=**}/invites/{id} { allow read: if isSignedIn(); }
    match /{path=**}/registrationEntries/{id} { allow read: if isSignedIn(); }
    match /{path=**}/members/{id} { allow read: if isSignedIn(); }
    match /{path=**}/events/{id} { allow read: if isSignedIn(); }
    match /{path=**}/files/{id} { allow read: if isSignedIn(); }
    match /{path=**}/signatures/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/incidents/{id} { allow read, write: if isSignedIn(); }

    // --- GLOBAL DEFAULT DENY ---
    
    match /{path=**} {
      allow read, write: if false;
    }
  }
}