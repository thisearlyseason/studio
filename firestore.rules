
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.get('email', '') == 'thisearlyseason@gmail.com' || 
        request.auth.token.get('email', '') == 'test@gmail.com'
      );
    }

    function isDemoTeam(tid) {
      // Robust string slicing for query-safe authorization
      return tid != null && tid is string && tid.size() >= 5 && tid[0:5] == 'demo_';
    }

    function isTeamMember(teamId) {
      return isSignedIn() && (
        isDemoTeam(teamId) || 
        isSuperAdmin() ||
        exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid))
      );
    }

    function isTeamAdmin(teamId) {
      return isSignedIn() && (
        isDemoTeam(teamId) ||
        isSuperAdmin() ||
        (exists(/databases/$(database)/documents/teams/$(teamId)) && (
          get(/databases/$(database)/documents/teams/$(teamId)).data.get('ownerUserId', '') == request.auth.uid ||
          (exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid)).data.get('role', '') == 'Admin')
        ))
      );
    }

    function isParent() {
      return isSignedIn() && (
        isSuperAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'parent')
      );
    }

    // Leagues Hub - Simplified top-level rule for query-safe listing
    match /leagues/{leagueId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSuperAdmin() || (isSignedIn() && resource.data.creatorId == request.auth.uid);
      
      match /registration/config {
        allow read: if true;
        allow write: if isSuperAdmin() || (isSignedIn() && get(/databases/$(database)/documents/leagues/$(leagueId)).data.creatorId == request.auth.uid);
      }
      
      match /registrationEntries/{entryId} {
        allow list: if isSignedIn();
        allow get: if isSignedIn();
        allow create: if true;
        allow update, delete: if isSuperAdmin() || (isSignedIn() && get(/databases/$(database)/documents/leagues/$(leagueId)).data.creatorId == request.auth.uid);
      }
      
      match /invites/{inviteId} {
        allow list: if isSignedIn();
        allow get: if isSignedIn();
        allow create: if isSuperAdmin() || (isSignedIn() && get(/databases/$(database)/documents/leagues/$(leagueId)).data.creatorId == request.auth.uid);
        allow update: if isSignedIn();
      }
    }

    // Clubs & Organizations
    match /clubs/{clubId} {
      allow read, write: if isSignedIn();
    }

    // Teams Hub
    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isTeamAdmin(teamId);

      match /volunteers/{oppId} {
        allow read: if isTeamAdmin(teamId) || isParent();
        allow create, delete: if isTeamAdmin(teamId);
        allow update: if isTeamAdmin(teamId) || isParent();
      }

      match /fundraising/{fundId} {
        allow read: if isTeamAdmin(teamId) || isParent();
        allow create, delete: if isTeamAdmin(teamId);
        allow update: if isTeamAdmin(teamId) || isParent();
      }

      match /members/{memberId} {
        allow read: if isSignedIn();
        allow write: if isTeamAdmin(teamId) || isOwner(memberId);
      }

      match /groupChats/{chatId} {
        // Consolidated list logic for query safety
        allow get, list: if isSignedIn() && (isDemoTeam(teamId) || isTeamMember(teamId));
        allow create: if isTeamMember(teamId);
        allow update: if isTeamMember(teamId) && (isTeamAdmin(teamId) || request.auth.uid in resource.data.memberIds);
        
        match /messages/{messageId} {
          allow read: if isTeamMember(teamId);
          allow create: if isTeamMember(teamId);
          allow update: if isTeamMember(teamId);
        }
      }
      
      match /events/{eventId} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId);
        
        match /registrations/{regId} {
          allow list, get: if isTeamMember(teamId);
          allow create: if true; // Public signups
          allow update, delete: if isTeamAdmin(teamId);
        }
      }

      match /games/{gameId} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId);
      }
      
      match /drills/{drillId} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId);
      }

      match /files/{fileId} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId);
      }

      match /alerts/{alertId} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId);
      }

      match /feedPosts/{postId} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId);
        
        match /comments/{commentId} {
          allow read: if isTeamMember(teamId);
          allow create: if isTeamMember(teamId);
          allow delete: if isTeamAdmin(teamId) || resource.data.authorId == request.auth.uid;
        }
      }
    }

    match /users/{userId} {
      allow read, update, delete: if isOwner(userId) || isSuperAdmin();
      allow create: if isSignedIn(); 
      
      match /teamMemberships/{membershipId} {
        allow read: if isOwner(userId) || isSuperAdmin();
        allow write: if isOwner(userId) || isSuperAdmin();
      }
    }

    // Global Invites Access
    match /leagues/global/invites/{inviteId} {
      allow read: if isSignedIn() && (request.auth.token.get('email', '').lower() == resource.data.invitedEmail.lower());
      allow write: if isSignedIn();
    }

    // Collection Group Queries for Dashboard/Recruitment
    match /{path=**}/members/{memberId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/events/{eventId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/alerts/{alertId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/registrationEntries/{entryId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /payments/{paymentId} {
      allow read, write: if isSignedIn();
    }

    match /players/{playerId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.parentId == request.auth.uid || isSuperAdmin());
    }

    match /plans/{planId} {
      allow get, list: if true;
    }

    match /features/{featureId} {
      allow get, list: if true;
    }

    match /leads/{leadId} {
      allow create: if true;
    }
  }
}
