rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- TACTICAL HELPERS ---

    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- INSTITUTIONAL HIERARCHY ---
    
    // Leagues and their nested coordination data
    match /leagues/{leagueId} {
      allow read, write: if isSignedIn();
      
      // Explicit matches for provable list operations
      match /registrationEntries/{id} { 
        allow list, read, write: if isSignedIn(); 
      }
      
      match /invites/{id} { 
        allow list, read, write: if isSignedIn(); 
      }

      match /events/{id} { 
        allow list, read, write: if isSignedIn(); 
      }
      
      match /members/{id} { 
        allow list, read, write: if isSignedIn(); 
      }
      
      match /payments/{id} { 
        allow list, read, write: if isSignedIn(); 
      }

      match /registration/{configId} {
        allow read, write: if isSignedIn();
      }

      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // Teams and their nested operational data
    match /teams/{teamId} {
      allow read, write: if isSignedIn();
      
      // Explicit matches for provable list operations
      match /members/{id} { allow list, read, write: if isSignedIn(); }
      match /events/{id} { allow list, read, write: if isSignedIn(); }
      match /files/{id} { allow list, read, write: if isSignedIn(); }
      match /equipment/{id} { allow list, read, write: if isSignedIn(); }
      match /volunteers/{id} { allow list, read, write: if isSignedIn(); }
      match /drills/{id} { allow list, read, write: if isSignedIn(); }
      match /incidents/{id} { allow list, read, write: if isSignedIn(); }
      match /games/{id} { allow list, read, write: if isSignedIn(); }
      match /registrationEntries/{id} { allow list, read, write: if isSignedIn(); }
      
      match /feedPosts/{id} { 
        allow list, read, write: if isSignedIn(); 
        match /comments/{commentId} { allow list, read, write: if isSignedIn(); }
      }
      
      match /groupChats/{id} { 
        allow list, read, write: if isSignedIn(); 
        match /messages/{msgId} { allow list, read, write: if isSignedIn(); }
      }
      
      match /fundraising/{id} { 
        allow list, read, write: if isSignedIn(); 
        match /donations/{donId} { allow list, read, write: if isSignedIn(); }
      }

      match /documents/{id} {
        allow list, read, write: if isSignedIn();
      }

      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- GLOBAL REPOSITORIES ---

    match /plans/{planId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /features/{featureId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /facilities/{facilityId} {
      allow read, write: if isSignedIn();
      match /fields/{fieldId} { allow list, read, write: if isSignedIn(); }
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    match /team_memberships/{membershipId} {
      allow read, write: if isSignedIn();
    }

    // --- PERSONAL INFRASTRUCTURE ---
    
    match /userProfiles/{userId} {
      allow read, write: if isOwner(userId);
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      // Explicit matches for provable list operations
      match /teamMemberships/{id} { allow list, read, write: if isOwner(userId); }
      match /hiddenChats/{id} { allow list, read, write: if isOwner(userId); }

      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    match /players/{playerId} {
      allow read, write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- COLLECTION GROUPS ---
    
    match /{path=**}/signatures/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/registrationEntries/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/members/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/events/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/files/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/incidents/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/feedPosts/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/groupChats/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/volunteers/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/fundraising/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/drills/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/games/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/equipment/{id} { allow read, write: if isSignedIn(); }

    // --- GLOBAL DEFAULT DENY ---
    match /{path=**} {
      allow read, write: if false;
    }
  }
}