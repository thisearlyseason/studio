
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- CORE HELPERS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isDemoId(id) {
      return id != null && id.size() >= 5 && id[0:5] == "demo_";
    }

    function isOwner(teamId) {
      return isSignedIn() && (
        get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUserId == request.auth.uid ||
        isDemoId(teamId)
      );
    }

    // --- USER PROFILES ---
    match /users/{userId} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isDemoId(userId));
      
      match /teamMemberships/{mId} {
        allow read, write: if isSignedIn() && (request.auth.uid == userId || isDemoId(userId));
      }
    }

    // --- PLAYERS (Family Hub) ---
    match /players/{playerId} {
      // Query-safe listing for the Family Hub
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (
        isDemoId(playerId) || 
        resource.data.guardianId == request.auth.uid
      );
      allow write: if isSignedIn() && (
        isDemoId(playerId) || 
        request.resource.data.guardianId == request.auth.uid
      );
    }

    // --- LEAGUES ---
    match /leagues/{leagueId} {
      // Statically verifiable listing for standings and recruitment
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow write: if isSignedIn() && (
        resource == null || 
        resource.data.creatorId == request.auth.uid || 
        isDemoId(leagueId)
      );

      match /registration/config {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && (
          get(/databases/$(database)/documents/leagues/$(leagueId)).data.creatorId == request.auth.uid || 
          isDemoId(leagueId)
        );
      }

      match /registrationEntries/{entryId} {
        allow list: if isSignedIn();
        allow get: if isSignedIn() && (
          get(/databases/$(database)/documents/leagues/$(leagueId)).data.creatorId == request.auth.uid ||
          resource.data.assigned_team_owner_id == request.auth.uid ||
          isDemoId(leagueId)
        );
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && (
          get(/databases/$(database)/documents/leagues/$(leagueId)).data.creatorId == request.auth.uid ||
          isDemoId(leagueId)
        );
      }
    }

    // --- TEAMS & SUBCOLLECTIONS ---
    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow write: if isOwner(teamId);

      match /members/{mId} { allow read: if isSignedIn(); allow write: if isOwner(teamId); }
      match /events/{eId} { 
        allow list: if isSignedIn(); 
        allow get: if isSignedIn(); 
        allow write: if isOwner(teamId); 
      }
      match /games/{gId} { allow read: if isSignedIn(); allow write: if isOwner(teamId); }
      match /drills/{dId} { allow read: if isSignedIn(); allow write: if isOwner(teamId); }
      match /files/{fId} { allow read: if isSignedIn(); allow write: if isOwner(teamId); }
      match /alerts/{aId} { allow read: if isSignedIn(); allow write: if isOwner(teamId); }
      match /volunteers/{vId} { allow read: if isSignedIn(); allow write: if isOwner(teamId); }
      match /fundraising/{fId} { allow read: if isSignedIn(); allow write: if isOwner(teamId); }
      
      match /groupChats/{cId} { 
        allow list: if isSignedIn();
        allow get: if isSignedIn();
        allow write: if isSignedIn(); 
        match /messages/{msgId} { allow read, write: if isSignedIn(); }
      }
      
      match /feedPosts/{pId} { 
        allow list: if isSignedIn();
        allow get: if isSignedIn();
        allow write: if isSignedIn();
        match /comments/{cId} { allow read, write: if isSignedIn(); }
      }
    }

    // --- ORGANIZATIONS ---
    match /organizations/{orgId} {
      allow read, write: if isSignedIn() && (request.auth.uid == orgId || isDemoId(orgId));
      match /facilities/{fId} { allow read, write: if isSignedIn(); }
    }

    // --- TOURNAMENTS ---
    match /tournaments/{tourneyId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (resource.data.creatorId == request.auth.uid || isDemoId(tourneyId));
    }

    match /matches/{matchId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /subscriptions/{subId} {
      allow read: if isSignedIn() && (request.auth.uid == subId || isDemoId(subId));
    }

    // --- COLLECTION GROUPS ---
    match /{path=**}/members/{mId} { allow read: if isSignedIn(); }
    match /{path=**}/events/{eId} { allow read: if isSignedIn(); }
    match /{path=**}/alerts/{aId} { allow read: if isSignedIn(); }
    match /{path=**}/registrationEntries/{eId} { allow read: if isSignedIn(); }
  }
}
